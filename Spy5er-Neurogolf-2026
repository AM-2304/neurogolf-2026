port onnx.numpy_helper as onh\nfrom onnx import TensorProto\n\ntry:\n    import onnxruntime as ort\nexcept ImportError:\n    os.system(\"pip install onnxruntime -q\")\n    import onnxruntime as ort\n\nimport torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# Device detection with compatibility check\nDEVICE = \"cpu\"\nif torch.cuda.is_available():\n    try:\n        _ = torch.zeros(1, device=\"cuda\")\n        DEVICE = \"cuda\"\n    except Exception:\n        DEVICE = \"cpu\"\n\nprint(f\"Device: {DEVICE}\")\nprint(f\"ONNX {onnx.__version__} | ORT {ort.__version__} | Torch {torch.__version__}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:02.641927Z","iopub.execute_input":"2026-04-18T12:53:02.642270Z","iopub.status.idle":"2026-04-18T12:53:13.025013Z","shell.execute_reply.started":"2026-04-18T12:53:02.642238Z","shell.execute_reply":"2026-04-18T12:53:13.024308Z"}},"outputs":[{"name":"stdout","text":"   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 17.2/17.2 MB 77.5 MB/s eta 0:00:00\nDevice: cuda\nONNX 1.20.1 | ORT 1.24.4 | Torch 2.10.0+cu128\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"# Constants & I/O Utilities","metadata":{}},{"cell_type":"code","source":"C, H, W = 10, 30, 30\nMAX_FILE_BYTES = int(1.44 * 1024 * 1024)\nDISALLOWED_OPS = {\"Loop\", \"Scan\", \"NonZero\", \"Unique\", \"Script\", \"Function\"}\nOPSET = [oh.make_opsetid(\"\", 17)]\nIR_VERSION = 8\n\nOUTPUT_DIR = Path(\"/kaggle/working\") if Path(\"/kaggle/working\").exists() else Path(\".\")\nTASK_DIR = Path(\"/kaggle/input/competitions/neurogolf-2026\")\n\nT0 = time.time()  # global timer\n\ndef grid_to_tensor(grid) -> np.ndarray:\n    g = np.asarray(grid, dtype=np.int32)\n    h, w = g.shape\n    t = np.zeros((1, C, H, W), dtype=np.float32)\n    for r in range(h):\n        for c_idx in range(w):\n            v = int(g[r, c_idx])\n            if 0 <= v < C:\n                t[0, v, r, c_idx] = 1.0\n    return t\n\n\ndef tensor_to_grid(t: np.ndarray, out_h: int, out_w: int) -> List[List[int]]:\n    arr = t[0, :, :out_h, :out_w]\n    grid = []\n    for r in range(out_h):\n        row = []\n        for c_idx in range(out_w):\n            col = arr[:, r, c_idx]\n            row.append(0 if col.max() < 0.5 else int(np.argmax(col)))\n        grid.append(row)\n    return grid\n\n\ndef find_task_files() -> List[Path]:\n    candidates = [\n        TASK_DIR,\n        Path(\"/kaggle/input/neurogolf-2026\"),\n        Path(\"/kaggle/input\"),\n        Path(\".\"),\n    ]\n    for d in candidates:\n        if d.exists():\n            files = sorted(d.glob(\"task*.json\"))\n            if files:\n                return files\n    for root, _, files in os.walk(\"/kaggle/input\" if Path(\"/kaggle/input\").exists() else \".\"):\n        hits = [Path(root) / f for f in files if f.startswith(\"task\") and f.endswith(\".json\")]\n        if hits:\n            return sorted(hits)\n    return []\n\n\ndef find_prebuilt_onnx() -> Dict[str, List[Path]]:\n    \"\"\"Find all prebuilt ONNX solutions in attached Kaggle datasets (handles .zip and .onnx).\"\"\"\n    paths = {}\n    search_dirs = [Path(\"/kaggle/input\")]\n    \n    # Temporary directory to extract zip contents\n    extract_dir = Path(\"/kaggle/working/extracted_prebuilts\")\n    extract_dir.mkdir(parents=True, exist_ok=True)\n    \n    for base in search_dirs:\n        if base.exists():\n            # 1. Find raw .onnx files\n            for p in base.rglob(\"*.onnx\"):\n                task_name = p.stem\n                if task_name.startswith(\"task\"):\n                    paths.setdefault(task_name, []).append(p)\n                    \n            # 2. Find and extract from .zip files (e.g., submission.zip from other notebooks)\n            for p in base.rglob(\"*.zip\"):\n                try:\n                    with zipfile.ZipFile(p, 'r') as zf:\n                        for fname in zf.namelist():\n                            if fname.endswith(\".onnx\") and fname.startswith(\"task\"):\n                                task_name = Path(fname).stem\n                                # Use parent dir name to avoid collisions if multiple submission.zip exist\n                                out_path = extract_dir / f\"{p.parent.name}_{fname}\"\n                                if not out_path.exists():\n                                    out_path.write_bytes(zf.read(fname))\n                                paths.setdefault(task_name, []).append(out_path)\n                except Exception as e:\n                    print(f\"Warning: Failed to read zip {p}: {e}\")\n                    pass\n    return paths\n\n\n\ndef load_task(path: Path) -> dict:\n    with open(path) as f:\n        data = json.load(f)\n    # Load arc-gen data for verification (cap at 5 for speed)\n    task_name = path.stem\n    arc_gen_pairs = []\n    for base in [path.parent, path.parent.parent]:\n        ag_dir = base / \"arc-gen\" / task_name\n        if ag_dir.is_dir():\n            for jf in sorted(ag_dir.glob(\"*.json\"))[:5]:\n                try:\n                    with open(jf) as f2:\n                        pair = json.load(f2)\n                    if \"input\" in pair and \"output\" in pair:\n                        arc_gen_pairs.append(pair)\n                except Exception:\n                    pass\n            break\n    data[\"arc_gen\"] = arc_gen_pairs\n    return data\n\n\ndef get_all_pairs(task_data):\n    \"\"\"Get train + test + arc-gen pairs (capped for speed).\"\"\"\n    pairs = list(task_data.get(\"train\", []) or [])\n    pairs += list(task_data.get(\"test\", []) or [])\n    pairs += list(task_data.get(\"arc_gen\", []) or [])[:5]\n    return pairs\n\n\ndef get_train_pairs(task_data):\n    \"\"\"Get train + test pairs (no arc-gen).\"\"\"\n    pairs = list(task_data.get(\"train\", []) or [])\n    pairs += list(task_data.get(\"test\", []) or [])\n    return pairs\n\n\ndef elapsed():\n    return time.time() - T0","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:13.025955Z","iopub.execute_input":"2026-04-18T12:53:13.026409Z","iopub.status.idle":"2026-04-18T12:53:13.042672Z","shell.execute_reply.started":"2026-04-18T12:53:13.026383Z","shell.execute_reply":"2026-04-18T12:53:13.042185Z"}},"outputs":[],"execution_count":3},{"cell_type":"markdown","source":"# ONNX Helpers, Cost, Verification","metadata":{}},{"cell_type":"code","source":"def _ft(name, arr):\n    return oh.make_tensor(name, TensorProto.FLOAT, list(arr.shape),\n                          arr.astype(np.float32).flatten().tolist())\n\ndef _it(name, arr):\n    return oh.make_tensor(name, TensorProto.INT64, list(arr.shape),\n                          arr.astype(np.int64).flatten().tolist())\n\ndef _const(name, arr):\n    t = onh.from_array(arr, name=name + \"_v\")\n    return oh.make_node(\"Constant\", [], [name], value=t)\n\ndef _X():\n    return oh.make_tensor_value_info(\"input\", TensorProto.FLOAT, [1, C, H, W])\n\ndef _Y():\n    return oh.make_tensor_value_info(\"output\", TensorProto.FLOAT, [1, C, H, W])\n\ndef _make_model(nodes, graph_name=\"net\"):\n    g = oh.make_graph(nodes, graph_name, [_X()], [_Y()])\n    m = oh.make_model(g, opset_imports=OPSET)\n    m.ir_version = IR_VERSION\n    return m\n\ndef _make_model_with_inits(nodes, inits, graph_name=\"net\"):\n    \"\"\"Build model with explicit initializers (for Conv weights etc.).\"\"\"\n    g = oh.make_graph(nodes, graph_name, [_X()], [_Y()], inits)\n    m = oh.make_model(g, opset_imports=OPSET)\n    m.ir_version = IR_VERSION\n    return m\n\ndef model_bytes(model) -> bytes:\n    return model.SerializeToString()\n\ndef check_fits(model) -> bool:\n    return len(model_bytes(model)) <= MAX_FILE_BYTES\n\ndef check_ops_allowed(model) -> bool:\n    return all(n.op_type not in DISALLOWED_OPS for n in model.graph.node)\n\n\ndef _iter_constants(model):\n    for init in model.graph.initializer:\n        yield onh.to_array(init)\n    for node in model.graph.node:\n        if node.op_type == \"Constant\":\n            for attr in node.attribute:\n                if attr.name == \"value\":\n                    yield onh.to_array(attr.t)\n\n\ndef count_params(model) -> int:\n    return sum(int(a.size) for a in _iter_constants(model))\n\n\ndef _shape_map(model):\n    shapes = {}\n    for vi in list(model.graph.input) + list(model.graph.output):\n        shapes[vi.name] = tuple(\n            d.dim_value if d.dim_value > 0 else 1\n            for d in vi.type.tensor_type.shape.dim\n        )\n    for init in model.graph.initializer:\n        shapes[init.name] = tuple(init.dims)\n    for node in model.graph.node:\n        if node.op_type == \"Constant\":\n            for attr in node.attribute:\n                if attr.name == \"value\":\n                    shapes[node.output[0]] = tuple(attr.t.dims) if attr.t.dims else ()\n    return shapes\n\n\ndef estimate_macs(model) -> int:\n    macs = 0\n    shapes = _shape_map(model)\n    for node in model.graph.node:\n        if node.op_type == \"Conv\":\n            w = shapes.get(node.input[1] if len(node.input) >= 2 else \"\")\n            if w and len(w) == 4:\n                out_c, in_c, kh, kw = w\n                macs += int(out_c * in_c * kh * kw * H * W)\n        elif node.op_type in (\"Gemm\", \"MatMul\"):\n            if len(node.input) >= 2:\n                a = shapes.get(node.input[0])\n                b = shapes.get(node.input[1])\n                if a and b and len(a) >= 2 and len(b) >= 2:\n                    macs += int(a[-1]) * int(b[-1]) * int(a[-2] if len(a) > 1 else 1)\n    return macs\n\n\ndef compute_cost(model) -> int:\n    params = count_params(model)\n    nbytes = len(model_bytes(model))\n    macs = estimate_macs(model)\n    return params + nbytes + macs\n\n\ndef compute_score(cost_val) -> float:\n    return max(1.0, 25.0 - math.log(max(1, cost_val)))\n\n\ndef check_model_correct(model, pairs) -> bool:\n    \"\"\"Verify ONNX model against all pairs using onnxruntime.\"\"\"\n    if not pairs:\n        return False\n    if not check_fits(model) or not check_ops_allowed(model):\n        return False\n    try:\n        so = ort.SessionOptions()\n        so.log_severity_level = 3\n        sess = ort.InferenceSession(\n            model_bytes(model), sess_options=so,\n            providers=[\"CPUExecutionProvider\"]\n        )\n    except Exception:\n        return False\n    try:\n        for p in pairs:\n            inp = grid_to_tensor(p[\"input\"])\n            og = np.asarray(p[\"output\"])\n            oh_, ow_ = og.shape\n            pred = sess.run(None, {\"input\": inp})[0]\n            # Check outside area is near-zero\n            outside = pred.copy()\n            outside[0, :, :oh_, :ow_] = 0.0\n            if np.max(np.abs(outside)) > 1e-4:\n                return False\n            if tensor_to_grid(pred, oh_, ow_) != p[\"output\"]:\n                return False\n        return True\n    except Exception:\n        return False","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:13.043665Z","iopub.execute_input":"2026-04-18T12:53:13.044128Z","iopub.status.idle":"2026-04-18T12:53:13.061598Z","shell.execute_reply.started":"2026-04-18T12:53:13.044105Z","shell.execute_reply":"2026-04-18T12:53:13.060930Z"}},"outputs":[],"execution_count":4},{"cell_type":"markdown","source":"# Model Builders (Geometric + Analytic ONNX)","metadata":{}},{"cell_type":"code","source":"# --- Geometric Primitives ---\n\ndef _pad_to_canvas(in_name, out_name, out_h, out_w, suf=\"\"):\n    pads = np.asarray([0,0,0,0, 0,0,H-out_h,W-out_w], dtype=np.int64)\n    return [\n        _const(f\"pd{suf}\", pads),\n        oh.make_node(\"Pad\", [in_name, f\"pd{suf}\"], [out_name], mode=\"constant\"),\n    ]\n\ndef _crop_to_content(in_name, out_name, h, w, suf=\"\"):\n    return [\n        _const(f\"cs{suf}\", np.asarray([0,0], dtype=np.int64)),\n        _const(f\"ce{suf}\", np.asarray([h,w], dtype=np.int64)),\n        _const(f\"ca{suf}\", np.asarray([2,3], dtype=np.int64)),\n        oh.make_node(\"Slice\", [in_name, f\"cs{suf}\", f\"ce{suf}\", f\"ca{suf}\"], [out_name]),\n    ]\n\ndef _slice_reverse(axes, dims, in_name, out_name, suf=\"\"):\n    starts = [d-1 for d in dims]\n    ends = [-d-1 for d in dims]\n    steps = [-1]*len(dims)\n    return [\n        _const(f\"rs_s{suf}\", np.asarray(starts, dtype=np.int64)),\n        _const(f\"rs_e{suf}\", np.asarray(ends, dtype=np.int64)),\n        _const(f\"rs_a{suf}\", np.asarray(axes, dtype=np.int64)),\n        _const(f\"rs_p{suf}\", np.asarray(steps, dtype=np.int64)),\n        oh.make_node(\"Slice\",\n                     [in_name, f\"rs_s{suf}\", f\"rs_e{suf}\", f\"rs_a{suf}\", f\"rs_p{suf}\"],\n                     [out_name]),\n    ]\n\n# Zero-cost geometric models\ndef make_identity():\n    return _make_model([oh.make_node(\"Identity\", [\"input\"], [\"output\"])], \"identity\")\n\ndef make_transpose_hw():\n    return _make_model(\n        [oh.make_node(\"Transpose\", [\"input\"], [\"output\"], perm=[0,1,3,2])], \"transpose_hw\")\n\ndef make_flip_h():\n    return _make_model(_slice_reverse([2],[H],\"input\",\"output\"), \"flip_h\")\n\ndef make_flip_w():\n    return _make_model(_slice_reverse([3],[W],\"input\",\"output\"), \"flip_w\")\n\ndef make_flip_both():\n    return _make_model(_slice_reverse([2,3],[H,W],\"input\",\"output\"), \"flip_both\")\n\ndef make_rot_180():\n    return make_flip_both()\n\ndef make_rot_90_cw():\n    nodes = [oh.make_node(\"Transpose\",[\"input\"],[\"t\"],perm=[0,1,3,2])]\n    nodes += _slice_reverse([3],[W],\"t\",\"output\")\n    return _make_model(nodes,\"rot90cw\")\n\ndef make_rot_90_ccw():\n    nodes = [oh.make_node(\"Transpose\",[\"input\"],[\"t\"],perm=[0,1,3,2])]\n    nodes += _slice_reverse([2],[H],\"t\",\"output\")\n    return _make_model(nodes,\"rot90ccw\")\n\ndef make_anti_transpose():\n    nodes = [oh.make_node(\"Transpose\",[\"input\"],[\"t\"],perm=[0,1,3,2])]\n    nodes += _slice_reverse([2,3],[H,W],\"t\",\"output\")\n    return _make_model(nodes,\"anti_transpose\")\n\n# Framed variants\ndef make_framed_rot180(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += _slice_reverse([2,3],[h,w],\"content\",\"rotated\",\"r\")\n    nodes += _pad_to_canvas(\"rotated\",\"output\",h,w,\"p\")\n    return _make_model(nodes,\"framed_rot180\")\n\ndef make_framed_flip_h(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += _slice_reverse([2],[h],\"content\",\"flipped\",\"r\")\n    nodes += _pad_to_canvas(\"flipped\",\"output\",h,w,\"p\")\n    return _make_model(nodes,\"framed_flip_h\")\n\ndef make_framed_flip_w(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += _slice_reverse([3],[w],\"content\",\"flipped\",\"r\")\n    nodes += _pad_to_canvas(\"flipped\",\"output\",h,w,\"p\")\n    return _make_model(nodes,\"framed_flip_w\")\n\ndef make_framed_transpose(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += [oh.make_node(\"Transpose\",[\"content\"],[\"transposed\"],perm=[0,1,3,2])]\n    nodes += _pad_to_canvas(\"transposed\",\"output\",w,h,\"p\")\n    return _make_model(nodes,\"framed_transpose\")\n\ndef make_framed_rot_90_cw(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += [oh.make_node(\"Transpose\",[\"content\"],[\"t\"],perm=[0,1,3,2])]\n    nodes += _slice_reverse([3],[h],\"t\",\"rotated\",\"r\")\n    nodes += _pad_to_canvas(\"rotated\",\"output\",w,h,\"p\")\n    return _make_model(nodes,\"framed_rot90cw\")\n\ndef make_framed_rot_90_ccw(h,w):\n    nodes = _crop_to_content(\"input\",\"content\",h,w,\"0\")\n    nodes += [oh.make_node(\"Transpose\",[\"content\"],[\"t\"],perm=[0,1,3,2])]\n    nodes += _slice_reverse([2],[w],\"t\",\"rotated\",\"r\")\n    nodes += _pad_to_canvas(\"rotated\",\"output\",w,h,\"p\")\n    return _make_model(nodes,\"framed_rot90ccw\")\n\n# Color remap via Gather\ndef make_color_remap_gather(color_map):\n    inv = {d:s for s,d in color_map.items()}\n    idx = np.arange(C, dtype=np.int64)\n    mask = np.ones(C, dtype=np.float32)\n    src_gone = {s for s,d in color_map.items() if s!=d}\n    for d in range(C):\n        if d in inv: idx[d] = inv[d]\n        elif d in src_gone: idx[d] = 0; mask[d] = 0.0\n        else: idx[d] = d\n    gi = _const(\"gi\", idx)\n    gnode = oh.make_node(\"Gather\",[\"input\",\"gi\"],[\"gathered\" if mask.min()<1 else \"output\"],axis=1)\n    if mask.min() == 1.0:\n        return _make_model([gi,gnode],\"color_remap\")\n    mk = _const(\"cm\",mask.reshape(1,C,1,1))\n    mul = oh.make_node(\"Mul\",[\"gathered\",\"cm\"],[\"output\"])\n    return _make_model([gi,gnode,mk,mul],\"color_remap_masked\")\n\n# Crop / translation / scale / tile / concat / border / const\ndef make_crop(r0,c0,oh_,ow_):\n    nodes = [\n        _const(\"cs\",np.asarray([r0,c0],dtype=np.int64)),\n        _const(\"ce\",np.asarray([r0+oh_,c0+ow_],dtype=np.int64)),\n        _const(\"ca\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"cs\",\"ce\",\"ca\"],[\"cropped\"]),\n    ]\n    nodes += _pad_to_canvas(\"cropped\",\"output\",oh_,ow_,\"p\")\n    return _make_model(nodes,\"crop_net\")\n\ndef make_translation(dr,dc):\n    sr0=max(0,-dr); sr1=min(H,H-dr)\n    sc0=max(0,-dc); sc1=min(W,W-dc)\n    dr0=max(0,dr); dc0=max(0,dc)\n    rh=sr1-sr0; rw=sc1-sc0\n    if rh<=0 or rw<=0: return None\n    pads = np.asarray([0,0,dr0,dc0,0,0,H-dr0-rh,W-dc0-rw],dtype=np.int64)\n    nodes = [\n        _const(\"ts\",np.asarray([sr0,sc0],dtype=np.int64)),\n        _const(\"te\",np.asarray([sr1,sc1],dtype=np.int64)),\n        _const(\"ta\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"ts\",\"te\",\"ta\"],[\"sliced\"]),\n        _const(\"pp\",pads),\n        oh.make_node(\"Pad\",[\"sliced\",\"pp\"],[\"output\"],mode=\"constant\"),\n    ]\n    return _make_model(nodes,\"translate_net\")\n\ndef make_framed_translation(gh,gw,dr,dc):\n    sr0=max(0,-dr); sr1=min(gh,gh-dr)\n    sc0=max(0,-dc); sc1=min(gw,gw-dc)\n    dr0=max(0,dr); dc0=max(0,dc)\n    rh=sr1-sr0; rw=sc1-sc0\n    if rh<=0 or rw<=0: return None\n    pads = np.asarray([0,0,dr0,dc0,0,0,H-dr0-rh,W-dc0-rw],dtype=np.int64)\n    nodes = [\n        _const(\"fts\",np.asarray([sr0,sc0],dtype=np.int64)),\n        _const(\"fte\",np.asarray([sr1,sc1],dtype=np.int64)),\n        _const(\"fta\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"fts\",\"fte\",\"fta\"],[\"fsliced\"]),\n        _const(\"fpp\",pads),\n        oh.make_node(\"Pad\",[\"fsliced\",\"fpp\"],[\"output\"],mode=\"constant\"),\n    ]\n    return _make_model(nodes,\"framed_translate\")\n\ndef make_upscale(f,in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += [\n        _const(\"rsz_roi\", np.asarray([],dtype=np.float32)),\n        _const(\"rsz_scales\", np.asarray([],dtype=np.float32)),\n        _const(\"rsz_sizes\", np.asarray([1,C,in_h*f,in_w*f],dtype=np.int64)),\n        oh.make_node(\"Resize\",[\"content\",\"rsz_roi\",\"rsz_scales\",\"rsz_sizes\"],[\"upscaled\"],\n                     mode=\"nearest\", coordinate_transformation_mode=\"asymmetric\",\n                     nearest_mode=\"floor\"),\n    ]\n    nodes += _pad_to_canvas(\"upscaled\",\"output\",in_h*f,in_w*f,\"p\")\n    return _make_model(nodes,\"upscale_net\")\n\ndef make_downscale(f,in_h,in_w):\n    out_h=in_h//f; out_w=in_w//f\n    nodes = [\n        _const(\"ds_s\",np.asarray([0,0],dtype=np.int64)),\n        _const(\"ds_e\",np.asarray([in_h,in_w],dtype=np.int64)),\n        _const(\"ds_a\",np.asarray([2,3],dtype=np.int64)),\n        _const(\"ds_p\",np.asarray([f,f],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"ds_s\",\"ds_e\",\"ds_a\",\"ds_p\"],[\"downsampled\"]),\n    ]\n    nodes += _pad_to_canvas(\"downsampled\",\"output\",out_h,out_w,\"p\")\n    return _make_model(nodes,\"downscale_net\")\n\ndef make_tile(tr,tc,in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += [\n        _const(\"tile_r\",np.asarray([1,1,tr,tc],dtype=np.int64)),\n        oh.make_node(\"Tile\",[\"content\",\"tile_r\"],[\"tiled\"]),\n    ]\n    nodes += _pad_to_canvas(\"tiled\",\"output\",in_h*tr,in_w*tc,\"p\")\n    return _make_model(nodes,\"tile_net\")\n\ndef make_concat_flip_w(in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += _slice_reverse([3],[in_w],\"content\",\"flipped\",\"fw\")\n    nodes += [oh.make_node(\"Concat\",[\"content\",\"flipped\"],[\"concated\"],axis=3)]\n    nodes += _pad_to_canvas(\"concated\",\"output\",in_h,in_w*2,\"p\")\n    return _make_model(nodes,\"concat_flip_w\")\n\ndef make_concat_flip_h(in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += _slice_reverse([2],[in_h],\"content\",\"flipped\",\"fh\")\n    nodes += [oh.make_node(\"Concat\",[\"content\",\"flipped\"],[\"concated\"],axis=2)]\n    nodes += _pad_to_canvas(\"concated\",\"output\",in_h*2,in_w,\"p\")\n    return _make_model(nodes,\"concat_flip_h\")\n\ndef make_concat_rot180_w(in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += _slice_reverse([2,3],[in_h,in_w],\"content\",\"rotated\",\"r\")\n    nodes += [oh.make_node(\"Concat\",[\"content\",\"rotated\"],[\"concated\"],axis=3)]\n    nodes += _pad_to_canvas(\"concated\",\"output\",in_h,in_w*2,\"p\")\n    return _make_model(nodes,\"concat_rot180_w\")\n\ndef make_quadrant_mirror(in_h,in_w):\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"0\")\n    nodes += _slice_reverse([3],[in_w],\"content\",\"fw\",\"fw\")\n    nodes += [oh.make_node(\"Concat\",[\"content\",\"fw\"],[\"top_row\"],axis=3)]\n    nodes += _slice_reverse([2],[in_h],\"content\",\"fh\",\"fh\")\n    nodes += _slice_reverse([2,3],[in_h,in_w],\"content\",\"fr\",\"fr\")\n    nodes += [oh.make_node(\"Concat\",[\"fh\",\"fr\"],[\"bot_row\"],axis=3)]\n    nodes += [oh.make_node(\"Concat\",[\"top_row\",\"bot_row\"],[\"full\"],axis=2)]\n    nodes += _pad_to_canvas(\"full\",\"output\",in_h*2,in_w*2,\"p\")\n    return _make_model(nodes,\"quadrant_mirror\")\n\ndef make_row_broadcast(in_h,in_w,row_idx):\n    nodes = [\n        _const(\"rb_s\",np.asarray([row_idx],dtype=np.int64)),\n        _const(\"rb_e\",np.asarray([row_idx+1],dtype=np.int64)),\n        _const(\"rb_a\",np.asarray([2],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"rb_s\",\"rb_e\",\"rb_a\"],[\"one_row\"]),\n        _const(\"rb_r\",np.asarray([1,1,in_h,1],dtype=np.int64)),\n        oh.make_node(\"Tile\",[\"one_row\",\"rb_r\"],[\"tiled\"]),\n        _const(\"rb_cs\",np.asarray([0,0],dtype=np.int64)),\n        _const(\"rb_ce\",np.asarray([in_h,in_w],dtype=np.int64)),\n        _const(\"rb_ca\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"tiled\",\"rb_cs\",\"rb_ce\",\"rb_ca\"],[\"cropped\"]),\n    ]\n    nodes += _pad_to_canvas(\"cropped\",\"output\",in_h,in_w,\"p\")\n    return _make_model(nodes,\"row_broadcast\")\n\ndef make_col_broadcast(in_h,in_w,col_idx):\n    nodes = [\n        _const(\"cb_s\",np.asarray([col_idx],dtype=np.int64)),\n        _const(\"cb_e\",np.asarray([col_idx+1],dtype=np.int64)),\n        _const(\"cb_a\",np.asarray([3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"cb_s\",\"cb_e\",\"cb_a\"],[\"one_col\"]),\n        _const(\"cb_r\",np.asarray([1,1,1,in_w],dtype=np.int64)),\n        oh.make_node(\"Tile\",[\"one_col\",\"cb_r\"],[\"tiled\"]),\n        _const(\"cb_cs\",np.asarray([0,0],dtype=np.int64)),\n        _const(\"cb_ce\",np.asarray([in_h,in_w],dtype=np.int64)),\n        _const(\"cb_ca\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"tiled\",\"cb_cs\",\"cb_ce\",\"cb_ca\"],[\"cropped\"]),\n    ]\n    nodes += _pad_to_canvas(\"cropped\",\"output\",in_h,in_w,\"p\")\n    return _make_model(nodes,\"col_broadcast\")\n\ndef make_const(output_grid):\n    og = np.asarray(output_grid, dtype=np.int32)\n    oh_, ow_ = og.shape\n    padded = np.zeros((1,C,H,W), dtype=np.float32)\n    for r in range(oh_):\n        for c_idx in range(ow_):\n            v = int(og[r,c_idx])\n            if 0 <= v < C:\n                padded[0,v,r,c_idx] = 1.0\n    nodes = [_const(\"K\",padded), oh.make_node(\"Identity\",[\"K\"],[\"output\"])]\n    return _make_model(nodes,\"const_net\")\n\ndef make_pad_with_border(grid_h,grid_w,border,fill_color):\n    oh_ = grid_h + 2*border; ow_ = grid_w + 2*border\n    if oh_>H or ow_>W: return None\n    nodes = _crop_to_content(\"input\",\"content\",grid_h,grid_w,\"pb0\")\n    pb_pads = np.asarray([0,0,border,border,0,0,border,border],dtype=np.int64)\n    nodes += [\n        _const(\"pb_pads\",pb_pads),\n        oh.make_node(\"Pad\",[\"content\",\"pb_pads\"],[\"padded\"],mode=\"constant\"),\n    ]\n    mask = np.zeros((1,C,oh_,ow_),dtype=np.float32)\n    if 0 <= fill_color < C:\n        mask[0,fill_color,:border,:] = 1.0\n        mask[0,fill_color,-border:,:] = 1.0\n        mask[0,fill_color,:,:border] = 1.0\n        mask[0,fill_color,:,-border:] = 1.0\n    nodes += [\n        _const(\"pb_mask\",mask),\n        oh.make_node(\"Add\",[\"padded\",\"pb_mask\"],[\"bordered\"]),\n    ]\n    nodes += _pad_to_canvas(\"bordered\",\"output\",oh_,ow_,\"pbf\")\n    return _make_model(nodes,\"pad_border\")\n\ndef make_crop_then_color(r0,c0,oh_,ow_,color_map):\n    nodes = [\n        _const(\"ctc_s\",np.asarray([r0,c0],dtype=np.int64)),\n        _const(\"ctc_e\",np.asarray([r0+oh_,c0+ow_],dtype=np.int64)),\n        _const(\"ctc_a\",np.asarray([2,3],dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"input\",\"ctc_s\",\"ctc_e\",\"ctc_a\"],[\"cropped\"]),\n    ]\n    inv = {d:s for s,d in color_map.items()}\n    idx = np.arange(C,dtype=np.int64)\n    mask = np.ones(C,dtype=np.float32)\n    src_gone = {s for s,d in color_map.items() if s!=d}\n    for d in range(C):\n        if d in inv: idx[d]=inv[d]\n        elif d in src_gone: idx[d]=0; mask[d]=0.0\n        else: idx[d]=d\n    gi = _const(\"gi_ctc\",idx)\n    if mask.min()==1.0:\n        gnode = oh.make_node(\"Gather\",[\"cropped\",\"gi_ctc\"],[\"colored\"],axis=1)\n        nodes += [gi,gnode]\n    else:\n        gnode = oh.make_node(\"Gather\",[\"cropped\",\"gi_ctc\"],[\"g_ctc\"],axis=1)\n        mk = _const(\"cm_ctc\",mask.reshape(1,C,1,1))\n        mul = oh.make_node(\"Mul\",[\"g_ctc\",\"cm_ctc\"],[\"colored\"])\n        nodes += [gi,gnode,mk,mul]\n    nodes += _pad_to_canvas(\"colored\",\"output\",oh_,ow_,\"ctcp\")\n    return _make_model(nodes,\"crop_color\")\n\ndef make_transform_plus_color(base_fn, color_map):\n    base = base_fn()\n    base_nodes = [copy.deepcopy(n) for n in base.graph.node]\n    for node in base_nodes:\n        for i,o in enumerate(node.output):\n            if o==\"output\": node.output[i]=\"mid\"\n    inv = {d:s for s,d in color_map.items()}\n    idx = np.arange(C,dtype=np.int64)\n    mask = np.ones(C,dtype=np.float32)\n    src_gone = {s for s,d in color_map.items() if s!=d}\n    for d in range(C):\n        if d in inv: idx[d]=inv[d]\n        elif d in src_gone: idx[d]=0; mask[d]=0.0\n        else: idx[d]=d\n    gi = _const(\"gi2\",idx)\n    if mask.min()==1.0:\n        gnode = oh.make_node(\"Gather\",[\"mid\",\"gi2\"],[\"output\"],axis=1)\n        return _make_model(base_nodes+[gi,gnode],\"xform_color\")\n    gnode = oh.make_node(\"Gather\",[\"mid\",\"gi2\"],[\"gathered2\"],axis=1)\n    mk = _const(\"cm2\",mask.reshape(1,C,1,1))\n    mul = oh.make_node(\"Mul\",[\"gathered2\",\"cm2\"],[\"output\"])\n    return _make_model(base_nodes+[gi,gnode,mk,mul],\"xform_color_masked\")\n\ndef make_self_similar_tile(in_h, in_w):\n    out_h = in_h * in_h; out_w = in_w * in_w\n    if out_h > H or out_w > W: return None\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"sst0\")\n    nodes += [\n        _const(\"sst_cs0\", np.asarray([0], dtype=np.int64)),\n        _const(\"sst_ce0\", np.asarray([1], dtype=np.int64)),\n        _const(\"sst_ca0\", np.asarray([1], dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"content\",\"sst_cs0\",\"sst_ce0\",\"sst_ca0\"],[\"bg_ch\"]),\n        _const(\"sst_one\", np.ones((1,1,1,1), dtype=np.float32)),\n        oh.make_node(\"Sub\",[\"sst_one\",\"bg_ch\"],[\"presence\"]),\n    ]\n    nodes += [\n        _const(\"sst_roi\", np.asarray([], dtype=np.float32)),\n        _const(\"sst_scales\", np.asarray([], dtype=np.float32)),\n        _const(\"sst_sizes\", np.asarray([1,1,out_h,out_w], dtype=np.int64)),\n        oh.make_node(\"Resize\",[\"presence\",\"sst_roi\",\"sst_scales\",\"sst_sizes\"],[\"pres_up\"],\n                     mode=\"nearest\", coordinate_transformation_mode=\"asymmetric\",\n                     nearest_mode=\"floor\"),\n    ]\n    nodes += [\n        _const(\"sst_reps\", np.asarray([1,1,in_h,in_w], dtype=np.int64)),\n        oh.make_node(\"Tile\",[\"content\",\"sst_reps\"],[\"tiled\"]),\n    ]\n    nodes += [oh.make_node(\"Mul\",[\"tiled\",\"pres_up\"],[\"masked\"])]\n    nodes += _pad_to_canvas(\"masked\",\"output\",out_h,out_w,\"sstp\")\n    return _make_model(nodes,\"self_similar_tile\")\n\n\n# --- Analytic Conv ONNX Builders (NEW - from LB794 architecture) ---\n\ndef make_conv_masked(W, B=None, dilation=1):\n    \"\"\"Single Conv + optional bias + ReduceMax content mask.\"\"\"\n    k = W.shape[2]\n    pad = dilation * (k // 2)\n    inits = [_ft(\"W\", W)]\n    if B is not None:\n        inits.append(_ft(\"B\", B))\n        nodes = [oh.make_node(\"Conv\", [\"input\", \"W\", \"B\"], [\"conv_out\"],\n                              kernel_shape=[k, k], pads=[pad]*4,\n                              dilations=[dilation, dilation])]\n    else:\n        nodes = [oh.make_node(\"Conv\", [\"input\", \"W\"], [\"conv_out\"],\n                              kernel_shape=[k, k], pads=[pad]*4,\n                              dilations=[dilation, dilation])]\n    nodes.append(oh.make_node(\"ReduceMax\", [\"input\"], [\"mask\"], axes=[1], keepdims=1))\n    nodes.append(oh.make_node(\"Mul\", [\"conv_out\", \"mask\"], [\"output\"]))\n    return _make_model_with_inits(nodes, inits, \"conv_masked\")\n\n\ndef make_conv_no_mask(W, dilation=1):\n    \"\"\"Single Conv, no bias, no mask.\"\"\"\n    k = W.shape[2]\n    pad = dilation * (k // 2)\n    inits = [_ft(\"W\", W)]\n    nodes = [oh.make_node(\"Conv\", [\"input\", \"W\"], [\"conv_out\"],\n                          kernel_shape=[k, k], pads=[pad]*4,\n                          dilations=[dilation, dilation])]\n    # Rename conv_out to output\n    nodes[0] = oh.make_node(\"Conv\", [\"input\", \"W\"], [\"output\"],\n                            kernel_shape=[k, k], pads=[pad]*4,\n                            dilations=[dilation, dilation])\n    return _make_model_with_inits(nodes, inits, \"conv_no_mask\")\n\n\ndef make_rcpool_model(Wl, Wr, Br, Wc, k, use_max=True):\n    \"\"\"Row-col pool: local_conv + row_pool_conv + col_pool_conv + mask.\"\"\"\n    pad = k // 2\n    pool_op = \"ReduceMax\" if use_max else \"ReduceMean\"\n    inits = [_ft(\"Wl\", Wl), _ft(\"Wr\", Wr), _ft(\"Br\", Br), _ft(\"Wc\", Wc)]\n    nodes = [\n        oh.make_node(\"Conv\", [\"input\", \"Wl\"], [\"local_f\"],\n                     kernel_shape=[k, k], pads=[pad]*4),\n        oh.make_node(pool_op, [\"input\"], [\"row_p\"], axes=[3], keepdims=1),\n        oh.make_node(\"Conv\", [\"row_p\", \"Wr\", \"Br\"], [\"row_f\"],\n                     kernel_shape=[1, 1], pads=[0,0,0,0]),\n        oh.make_node(pool_op, [\"input\"], [\"col_p\"], axes=[2], keepdims=1),\n        oh.make_node(\"Conv\", [\"col_p\", \"Wc\"], [\"col_f\"],\n                     kernel_shape=[1, 1], pads=[0,0,0,0]),\n        oh.make_node(\"Add\", [\"local_f\", \"row_f\"], [\"add1\"]),\n        oh.make_node(\"Add\", [\"add1\", \"col_f\"], [\"comb\"]),\n        oh.make_node(\"ReduceMax\", [\"input\"], [\"mask\"], axes=[1], keepdims=1),\n        oh.make_node(\"Mul\", [\"comb\", \"mask\"], [\"output\"]),\n    ]\n    return _make_model_with_inits(nodes, inits, \"rcpool\")\n\n\ndef make_fxo_conv_masked(W, B, OA_MASK, dilation=1):\n    \"\"\"Fixed-output Conv + bias + static OA mask (not ReduceMax).\"\"\"\n    k = W.shape[2]\n    pad = dilation * (k // 2)\n    inits = [_ft(\"W\", W), _ft(\"B\", B), _ft(\"OA_MASK\", OA_MASK)]\n    nodes = [\n        oh.make_node(\"Conv\", [\"input\", \"W\", \"B\"], [\"conv_out\"],\n                     kernel_shape=[k, k], pads=[pad]*4,\n                     dilations=[dilation, dilation]),\n        oh.make_node(\"Mul\", [\"conv_out\", \"OA_MASK\"], [\"output\"]),\n    ]\n    return _make_model_with_inits(nodes, inits, \"fxo_conv\")\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:13.062491Z","iopub.execute_input":"2026-04-18T12:53:13.062756Z","iopub.status.idle":"2026-04-18T12:53:13.233428Z","shell.execute_reply.started":"2026-04-18T12:53:13.062733Z","shell.execute_reply":"2026-04-18T12:53:13.232581Z"}},"outputs":[],"execution_count":5},{"cell_type":"markdown","source":"# Detectors","metadata":{}},{"cell_type":"code","source":"def all_same_io_shape(pairs) -> bool:\n    return all(np.asarray(p[\"input\"]).shape == np.asarray(p[\"output\"]).shape for p in pairs)\n\ndef fixed_input_size(pairs):\n    if not pairs: return None\n    first = np.asarray(pairs[0][\"input\"]).shape\n    return first if all(np.asarray(p[\"input\"]).shape == first for p in pairs[1:]) else None\n\ndef detect_identity(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.shape!=og.shape or not np.array_equal(ig,og): return False\n    return True\n\ndef detect_const(pairs):\n    if not pairs: return None\n    first=np.asarray(pairs[0][\"output\"])\n    for p in pairs[1:]:\n        o=np.asarray(p[\"output\"])\n        if o.shape!=first.shape or not np.array_equal(o,first): return None\n    if detect_identity(pairs): return None\n    return first\n\ndef detect_rotation(pairs):\n    for label,k in [(\"180\",2),(\"90cw\",-1),(\"90ccw\",1)]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            r=np.rot90(ig,k)\n            if r.shape!=og.shape or not np.array_equal(r,og): ok=False; break\n        if ok: return label\n    return None\n\ndef detect_flip(pairs):\n    for name,fn in [(\"h\",np.flipud),(\"w\",np.fliplr),(\"both\",lambda a:np.flipud(np.fliplr(a)))]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            if fn(ig).shape!=og.shape or not np.array_equal(fn(ig),og): ok=False; break\n        if ok: return name\n    return None\n\ndef detect_transpose(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.T.shape!=og.shape or not np.array_equal(ig.T,og): return False\n    return True\n\ndef detect_anti_transpose(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        exp=np.flipud(np.fliplr(ig.T))\n        if exp.shape!=og.shape or not np.array_equal(exp,og): return False\n    return True\n\ndef detect_color_map(pairs):\n    if not all_same_io_shape(pairs): return None\n    mapping = {}\n    for p in pairs:\n        for a,b in zip(np.asarray(p[\"input\"]).flatten().tolist(),\n                       np.asarray(p[\"output\"]).flatten().tolist()):\n            a,b=int(a),int(b)\n            if a in mapping and mapping[a]!=b: return None\n            mapping[a]=b\n    if all(k==v for k,v in mapping.items()): return None\n    return mapping\n\ndef detect_color_filter(pairs):\n    if not all_same_io_shape(pairs): return None\n    candidate=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        diff=(ig!=og)\n        if not np.any(diff): continue\n        if not np.all(og[diff]==0): return None\n        local=set(int(x) for x in ig[diff].tolist())\n        candidate=local if candidate is None else candidate|local\n    if not candidate: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]).copy()\n        for c_ in candidate: ig[ig==c_]=0\n        if not np.array_equal(ig,np.asarray(p[\"output\"])): return None\n    return candidate\n\ndef detect_fixed_crop(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    oh_,ow_=fst_out.shape; ih,iw=fst_in.shape\n    if oh_>ih or ow_>iw: return None\n    for r0 in range(ih-oh_+1):\n        for c0 in range(iw-ow_+1):\n            if not np.array_equal(fst_in[r0:r0+oh_,c0:c0+ow_],fst_out): continue\n            ok=True\n            for p in pairs[1:]:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if og.shape!=(oh_,ow_): ok=False; break\n                if r0+oh_>ig.shape[0] or c0+ow_>ig.shape[1]: ok=False; break\n                if not np.array_equal(ig[r0:r0+oh_,c0:c0+ow_],og): ok=False; break\n            if ok: return (r0,c0,oh_,ow_)\n    return None\n\ndef detect_translation(pairs):\n    if not all_same_io_shape(pairs): return None\n    fst_in=np.asarray(pairs[0][\"input\"]); ih,iw=fst_in.shape\n    for dr in range(-min(ih,11)+1,min(ih,11)):\n        for dc in range(-min(iw,11)+1,min(iw,11)):\n            if dr==0 and dc==0: continue\n            ok=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if ig.shape!=og.shape: ok=False; break\n                hh,ww=ig.shape\n                shifted=np.zeros_like(ig)\n                sr0=max(0,-dr); sr1=min(hh,hh-dr)\n                sc0=max(0,-dc); sc1=min(ww,ww-dc)\n                dr0=max(0,dr); dc0=max(0,dc)\n                rh=sr1-sr0; rw=sc1-sc0\n                if rh>0 and rw>0:\n                    shifted[dr0:dr0+rh,dc0:dc0+rw]=ig[sr0:sr1,sc0:sc1]\n                if not np.array_equal(shifted,og): ok=False; break\n            if ok: return (dr,dc)\n    return None\n\ndef detect_upscale(pairs):\n    for f in [2,3,4,5]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            ih,iw=ig.shape; oh_,ow_=og.shape\n            if oh_!=ih*f or ow_!=iw*f: ok=False; break\n            if ih*f>H or iw*f>W: ok=False; break\n            scaled=np.repeat(np.repeat(ig,f,axis=0),f,axis=1)\n            if not np.array_equal(scaled,og): ok=False; break\n        if ok: return f\n    return None\n\ndef detect_downscale(pairs):\n    for f in [2,3,4,5]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            ih,iw=ig.shape; oh_,ow_=og.shape\n            if ih!=oh_*f or iw!=ow_*f: ok=False; break\n            if not np.array_equal(ig[::f,::f],og): ok=False; break\n        if ok: return f\n    return None\n\ndef detect_tile(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    ih,iw=fst_in.shape; oh_,ow_=fst_out.shape\n    if ih==0 or iw==0 or oh_%ih!=0 or ow_%iw!=0: return None\n    tr,tc=oh_//ih,ow_//iw\n    if tr*ih>H or tc*iw>W or (tr==1 and tc==1): return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih2,iw2=ig.shape\n        if og.shape!=(ih2*tr,iw2*tc): return None\n        if not np.array_equal(np.tile(ig,(tr,tc)),og): return None\n    return (tr,tc)\n\ndef detect_concat_flip_w(pairs):\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih,iw*2): return None\n        if not np.array_equal(np.concatenate([ig,np.fliplr(ig)],axis=1),og): return None\n    return True\n\ndef detect_concat_flip_h(pairs):\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih*2,iw): return None\n        if not np.array_equal(np.concatenate([ig,np.flipud(ig)],axis=0),og): return None\n    return True\n\ndef detect_concat_rot180_w(pairs):\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih,iw*2): return None\n        if not np.array_equal(np.concatenate([ig,np.rot90(ig,2)],axis=1),og): return None\n    return True\n\ndef detect_quadrant_mirror(pairs):\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih*2,iw*2): return None\n        top=np.concatenate([ig,np.fliplr(ig)],axis=1)\n        bot=np.concatenate([np.flipud(ig),np.rot90(ig,2)],axis=1)\n        if not np.array_equal(np.concatenate([top,bot],axis=0),og): return None\n    return True\n\ndef detect_row_broadcast(pairs):\n    if not all_same_io_shape(pairs): return None\n    chosen=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"]); ih,_=ig.shape\n        matched=next((r for r in range(ih) if np.all(og==ig[r,:])),None)\n        if matched is None: return None\n        if chosen is None: chosen=matched\n        elif chosen!=matched: return None\n    return chosen\n\ndef detect_col_broadcast(pairs):\n    if not all_same_io_shape(pairs): return None\n    chosen=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"]); _,iw=ig.shape\n        matched=next((c_idx for c_idx in range(iw) if np.all(og==ig[:,c_idx:c_idx+1])),None)\n        if matched is None: return None\n        if chosen is None: chosen=matched\n        elif chosen!=matched: return None\n    return chosen\n\ndef detect_crop_plus_color(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    oh_,ow_=fst_out.shape; ih,iw=fst_in.shape\n    if oh_>ih or ow_>iw: return None\n    for r0 in range(ih-oh_+1):\n        for c0 in range(iw-ow_+1):\n            cmap={}; valid=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if og.shape!=(oh_,ow_): valid=False; break\n                if r0+oh_>ig.shape[0] or c0+ow_>ig.shape[1]: valid=False; break\n                region=ig[r0:r0+oh_,c0:c0+ow_]\n                for a,b in zip(region.flatten().tolist(),og.flatten().tolist()):\n                    a,b=int(a),int(b)\n                    if a in cmap and cmap[a]!=b: valid=False; break\n                    cmap[a]=b\n                if not valid: break\n            if not valid: continue\n            if all(k==v for k,v in cmap.items()): continue\n            ok=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                region=ig[r0:r0+oh_,c0:c0+ow_]\n                mapped=region.copy()\n                for k,v in cmap.items(): mapped[region==k]=v\n                if not np.array_equal(mapped,og): ok=False; break\n            if ok: return (r0,c0,oh_,ow_,cmap)\n    return None\n\ndef detect_border_add(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    ih,iw=fst_in.shape; oh_,ow_=fst_out.shape\n    if (oh_-ih)!=(ow_-iw): return None\n    delta=oh_-ih\n    if delta<=0 or delta%2!=0: return None\n    b=delta//2\n    if not np.array_equal(fst_out[b:b+ih,b:b+iw],fst_in): return None\n    vals=set(fst_out[:b,:].flatten().tolist())|set(fst_out[-b:,:].flatten().tolist())|set(fst_out[:,:b].flatten().tolist())|set(fst_out[:,-b:].flatten().tolist())\n    if len(vals)!=1: return None\n    fill=int(vals.pop())\n    for p in pairs[1:]:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih2,iw2=ig.shape\n        if og.shape!=(ih2+2*b,iw2+2*b): return None\n        if not np.array_equal(og[b:b+ih2,b:b+iw2],ig): return None\n    return (b,fill)\n\ndef detect_rotation_plus_color(pairs):\n    for rot_label,k in [(\"180\",2),(\"90cw\",-1),(\"90ccw\",1)]:\n        mapping={}; ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            r=np.rot90(ig,k)\n            if r.shape!=og.shape: ok=False; break\n            for a,b in zip(r.flatten().tolist(),og.flatten().tolist()):\n                a,b=int(a),int(b)\n                if a in mapping and mapping[a]!=b: ok=False; break\n                mapping[a]=b\n            if not ok: break\n        if ok and any(k2!=v for k2,v in mapping.items()): return (rot_label,mapping)\n    return None\n\ndef detect_flip_plus_color(pairs):\n    for name,fn in [(\"h\",np.flipud),(\"w\",np.fliplr),(\"both\",lambda a:np.flipud(np.fliplr(a)))]:\n        mapping={}; ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            f=fn(ig)\n            if f.shape!=og.shape: ok=False; break\n            for a,b in zip(f.flatten().tolist(),og.flatten().tolist()):\n                a,b=int(a),int(b)\n                if a in mapping and mapping[a]!=b: ok=False; break\n                mapping[a]=b\n            if not ok: break\n        if ok and any(k2!=v for k2,v in mapping.items()): return (name,mapping)\n    return None\n\ndef detect_transpose_plus_color(pairs):\n    mapping={}\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.T.shape!=og.shape: return None\n        for a,b in zip(ig.T.flatten().tolist(),og.flatten().tolist()):\n            a,b=int(a),int(b)\n            if a in mapping and mapping[a]!=b: return None\n            mapping[a]=b\n    if any(k!=v for k,v in mapping.items()): return mapping\n    return None\n\ndef detect_self_similar_tile(pairs):\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape; oh_,ow_=og.shape\n        if oh_!=ih*ih or ow_!=iw*iw: return None\n        if oh_>H or ow_>W: return None\n        for br in range(ih):\n            for bc in range(iw):\n                block=og[br*ih:(br+1)*ih, bc*iw:(bc+1)*iw]\n                if ig[br,bc]!=0:\n                    if not np.array_equal(block,ig): return None\n                else:\n                    if not np.all(block==0): return None\n    return True","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:13.234587Z","iopub.execute_input":"2026-04-18T12:53:13.234957Z","iopub.status.idle":"2026-04-18T12:53:13.283841Z","shell.execute_reply.started":"2026-04-18T12:53:13.234923Z","shell.execute_reply":"2026-04-18T12:53:13.283178Z"}},"outputs":[],"execution_count":6},{"cell_type":"markdown","source":"# Analytic Solver (lstsq) + CNN Training","metadata":{}},{"cell_type":"code","source":"def extract_patches(inp, k, dilation=1):\n    \"\"\"Extract k×k patches from each spatial position. inp: (C, H, W) → (C*k*k, H, W)\"\"\"\n    c_in, h, w = inp.shape\n    pad = dilation * (k // 2)\n    inp_padded = np.pad(inp, ((0,0),(pad,pad),(pad,pad)), mode='constant')\n    patches = np.zeros((c_in * k * k, h, w), dtype=np.float32)\n    idx = 0\n    for ci in range(c_in):\n        for ki in range(k):\n            for kj in range(k):\n                si = ki * dilation\n                sj = kj * dilation\n                patches[idx] = inp_padded[ci, si:si+h, sj:sj+w]\n                idx += 1\n    return patches\n\n\ndef solve_conv_analytic(pairs, k, dilation=1, use_bias=True, use_mask=True):\n    \"\"\"\n    Solve for Conv weights analytically using least squares.\n    Returns (W, B) or None if it fails.\n    W shape: (C, C, k, k), B shape: (C,) or None\n    \"\"\"\n    feat_dim = C * k * k\n    all_X = []\n    all_Y = []\n\n    for p in pairs:\n        inp = grid_to_tensor(p[\"input\"])[0]  # (10, 30, 30)\n        out = grid_to_tensor(p[\"output\"])[0]  # (10, 30, 30)\n        inp_h = len(p[\"input\"])\n        inp_w = len(p[\"input\"][0])\n        out_h = len(p[\"output\"])\n        out_w = len(p[\"output\"][0])\n\n        if use_mask:\n            mask = np.max(inp, axis=0) > 0  # (30, 30)\n            # Only use ReduceMax masking when I/O sizes match\n            if inp_h != out_h or inp_w != out_w:\n                # Use output area mask instead\n                mask = np.zeros((H, W), dtype=bool)\n                mask[:out_h, :out_w] = True\n        else:\n            mask = np.zeros((H, W), dtype=bool)\n            mask[:max(inp_h, out_h), :max(inp_w, out_w)] = True\n\n        patches = extract_patches(inp, k, dilation=dilation)  # (C*k*k, H, W)\n        X_flat = patches[:, mask].T  # (N_content, feat_dim)\n        Y_flat = out[:, mask].T      # (N_content, C)\n\n        if use_bias:\n            bias_col = np.ones((X_flat.shape[0], 1), dtype=np.float32)\n            X_flat = np.concatenate([X_flat, bias_col], axis=1)\n\n        all_X.append(X_flat)\n        all_Y.append(Y_flat)\n\n    X = np.concatenate(all_X, axis=0)\n    Y = np.concatenate(all_Y, axis=0)\n\n    if X.shape[0] < X.shape[1]:\n        return None  # Underdetermined\n\n    try:\n        W_sol, _, _, _ = np.linalg.lstsq(X, Y, rcond=None)\n    except Exception:\n        return None\n\n    # Check fit quality\n    pred = X @ W_sol\n    max_err = np.max(np.abs(pred - Y))\n    if max_err > 0.45:\n        return None\n\n    W_sol = W_sol.T  # (C, feat_dim+1) or (C, feat_dim)\n    if use_bias:\n        B = W_sol[:, -1].astype(np.float32)\n        W_conv = W_sol[:, :-1].reshape(C, C, k, k).astype(np.float32)\n    else:\n        B = None\n        W_conv = W_sol.reshape(C, C, k, k).astype(np.float32)\n\n    return W_conv, B\n\n\ndef solve_rcpool_analytic(pairs, k, use_max=True, use_bias=True):\n    \"\"\"\n    Solve for RCPool weights analytically.\n    Features = [local_patches, row_pool, col_pool, bias]\n    \"\"\"\n    feat_dim = C * k * k + C + C  # local + row + col\n    all_X = []\n    all_Y = []\n\n    for p in pairs:\n        inp = grid_to_tensor(p[\"input\"])[0]  # (C, H, W)\n        out = grid_to_tensor(p[\"output\"])[0]\n        inp_h = len(p[\"input\"])\n        inp_w = len(p[\"input\"][0])\n\n        mask = np.max(inp, axis=0) > 0  # (H, W)\n\n        # Local patches\n        patches = extract_patches(inp, k, dilation=1)  # (C*k*k, H, W)\n\n        # Row pool (max/mean over width)\n        if use_max:\n            row_pool = np.max(inp, axis=2, keepdims=True)  # (C, H, 1)\n        else:\n            row_pool = np.mean(inp, axis=2, keepdims=True)\n        row_pool_broadcast = np.broadcast_to(row_pool, (C, H, W))\n\n        # Col pool (max/mean over height)\n        if use_max:\n            col_pool = np.max(inp, axis=1, keepdims=True)  # (C, 1, W)\n        else:\n            col_pool = np.mean(inp, axis=1, keepdims=True)\n        col_pool_broadcast = np.broadcast_to(col_pool, (C, H, W))\n\n        # Combine features\n        features = np.concatenate([patches, row_pool_broadcast, col_pool_broadcast], axis=0)\n        # (C*k*k + C + C, H, W)\n\n        X_flat = features[:, mask].T  # (N, feat_dim)\n        Y_flat = out[:, mask].T\n\n        if use_bias:\n            bias_col = np.ones((X_flat.shape[0], 1), dtype=np.float32)\n            X_flat = np.concatenate([X_flat, bias_col], axis=1)\n\n        all_X.append(X_flat)\n        all_Y.append(Y_flat)\n\n    X = np.concatenate(all_X, axis=0)\n    Y = np.concatenate(all_Y, axis=0)\n\n    if X.shape[0] < X.shape[1]:\n        return None\n\n    try:\n        W_sol, _, _, _ = np.linalg.lstsq(X, Y, rcond=None)\n    except Exception:\n        return None\n\n    pred = X @ W_sol\n    max_err = np.max(np.abs(pred - Y))\n    if max_err > 0.45:\n        return None\n\n    W_sol = W_sol.T  # (C, feat_dim+1)\n    local_size = C * k * k\n    Wl = W_sol[:, :local_size].reshape(C, C, k, k).astype(np.float32)\n    Wr = W_sol[:, local_size:local_size+C].reshape(C, C, 1, 1).astype(np.float32)\n    Wc = W_sol[:, local_size+C:local_size+2*C].reshape(C, C, 1, 1).astype(np.float32)\n    if use_bias:\n        Br = W_sol[:, -1].astype(np.float32)\n    else:\n        Br = np.zeros(C, dtype=np.float32)\n\n    return Wl, Wr, Br, Wc\n\n\ndef try_analytic_solvers(pairs, all_pairs, time_limit=15):\n    \"\"\"\n    Try analytic solver configurations.\n    FAST: breaks on first success (configs are sorted cheapest-first).\n    Returns (model, label, cost) or (None, None, None).\n    \"\"\"\n    t0 = time.time()\n\n    # Configs sorted cheapest-first. Break on first hit.\n    conv_configs = [\n        (1, 1, False, True),   # 1x1 no-bias\n        (1, 1, True, True),    # 1x1 bias\n        (1, 1, False, False),  # 1x1 no mask\n        (3, 1, True, True),    # 3x3\n        (3, 1, False, True),   # 3x3 no-bias\n        (5, 1, True, True),    # 5x5\n        (7, 1, True, True),    # 7x7\n        (9, 1, True, True),    # 9x9\n        (11, 1, True, True),   # 11x11\n        (3, 2, True, True),    # dilated eff=5\n        (3, 3, True, True),    # dilated eff=7\n        (3, 4, True, True),    # dilated eff=9\n        (3, 5, True, True),    # dilated eff=11\n        (3, 6, True, True),    # dilated eff=13\n        (5, 2, True, True),    # dilated eff=9\n        (5, 3, True, True),    # dilated eff=13\n    ]\n\n    for k, dilation, use_bias, use_mask in conv_configs:\n        if time.time() - t0 > time_limit:\n            break\n        try:\n            result = solve_conv_analytic(pairs, k, dilation, use_bias, use_mask)\n            if result is None:\n                continue\n            W, B = result\n\n            if use_mask and use_bias:\n                model = make_conv_masked(W, B, dilation)\n            elif use_mask and not use_bias:\n                model = make_conv_masked(W, None, dilation)\n            elif not use_mask and not use_bias:\n                model = make_conv_no_mask(W, dilation)\n            else:\n                continue\n\n            if not check_fits(model):\n                continue\n            if not check_model_correct(model, all_pairs):\n                continue\n\n            c = compute_cost(model)\n            lbl = f\"lstsq_k{k}\" + (f\"d{dilation}\" if dilation > 1 else \"\") + \\\n                  (\"_b\" if use_bias else \"\") + (\"_m\" if use_mask else \"\")\n            return model, lbl, c  # EARLY EXIT: first success wins\n        except Exception:\n            continue\n\n    # RCPool (only try if conv failed)\n    for k, use_max, use_bias in [(1,True,True),(1,False,True),(3,True,True),(3,False,True)]:\n        if time.time() - t0 > time_limit:\n            break\n        try:\n            result = solve_rcpool_analytic(pairs, k, use_max, use_bias)\n            if result is None:\n                continue\n            Wl, Wr, Br, Wc = result\n            model = make_rcpool_model(Wl, Wr, Br, Wc, k, use_max)\n            if not check_fits(model):\n                continue\n            if not check_model_correct(model, all_pairs):\n                continue\n            c = compute_cost(model)\n            pool_type = \"max\" if use_max else \"mean\"\n            return model, f\"lstsq_rcpool_{pool_type}_k{k}\", c  # EARLY EXIT\n        except Exception:\n            continue\n\n    return None, None, None\n\n\n# --- CNN Training with ReduceMax Masking ---\n\nclass MaskedCNN(nn.Module):\n    \"\"\"CNN with built-in ReduceMax content masking.\"\"\"\n    def __init__(self, hidden, k, n_layers=1, dilation=1):\n        super().__init__()\n        pad = dilation * (k // 2)\n        layers = []\n        in_c = C\n        for _ in range(n_layers):\n            layers.append(nn.Conv2d(in_c, hidden, k, padding=pad, dilation=dilation))\n            layers.append(nn.ReLU())\n            in_c = hidden\n        layers.append(nn.Conv2d(in_c, C, 1))\n        self.net = nn.Sequential(*layers)\n\n    def forward(self, x):\n        mask = x.max(dim=1, keepdim=True)[0]  # ReduceMax → content mask\n        return self.net(x) * mask\n\n\nclass FXOMaskedCNN(nn.Module):\n    \"\"\"CNN with fixed-output mask (for tasks where I/O sizes differ).\"\"\"\n    def __init__(self, hidden, k, oa_mask, n_layers=1, dilation=1):\n        super().__init__()\n        pad = dilation * (k // 2)\n        layers = []\n        in_c = C\n        for _ in range(n_layers):\n            layers.append(nn.Conv2d(in_c, hidden, k, padding=pad, dilation=dilation))\n            layers.append(nn.ReLU())\n            in_c = hidden\n        layers.append(nn.Conv2d(in_c, C, 1))\n        self.net = nn.Sequential(*layers)\n        self.register_buffer('oa_mask', torch.from_numpy(oa_mask))\n\n    def forward(self, x):\n        return self.net(x) * self.oa_mask\n\n\ndef compute_oa_mask(pairs):\n    \"\"\"Compute the Output-Area mask: union of all output content regions.\"\"\"\n    mask = np.zeros((1, 1, H, W), dtype=np.float32)\n    for p in pairs:\n        og = np.asarray(p[\"output\"])\n        oh_, ow_ = og.shape\n        mask[0, 0, :oh_, :ow_] = 1.0\n    return mask\n\n\ndef train_cnn_model(pairs, hidden, k, n_layers=1, dilation=1, use_fxo=False,\n                    max_epochs=1500, n_restarts=1, patience=250, time_limit=45):\n    \"\"\"Train a MaskedCNN on the given pairs. Has internal time limit.\"\"\"\n    t_start = time.time()\n    # Prepare data\n    X = np.concatenate([grid_to_tensor(p[\"input\"]) for p in pairs], axis=0)\n    Y = np.concatenate([grid_to_tensor(p[\"output\"]) for p in pairs], axis=0)\n    X_t = torch.from_numpy(X).to(DEVICE)\n    Y_t = torch.from_numpy(Y).to(DEVICE)\n\n    same_io = all(np.asarray(p[\"input\"]).shape == np.asarray(p[\"output\"]).shape for p in pairs)\n    oa_mask = None\n    if not same_io or use_fxo:\n        oa_mask = compute_oa_mask(pairs)\n\n    best_loss = float('inf')\n    best_state = None\n\n    for restart in range(n_restarts):\n        if time.time() - t_start > time_limit:\n            break\n        if oa_mask is not None:\n            model = FXOMaskedCNN(hidden, k, oa_mask, n_layers, dilation).to(DEVICE)\n        else:\n            model = MaskedCNN(hidden, k, n_layers, dilation).to(DEVICE)\n\n        lr = 1e-2 if restart == 0 else 3e-3\n        optimizer = optim.Adam(model.parameters(), lr=lr)\n        scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=max_epochs, eta_min=1e-5)\n\n        no_improve = 0\n        for epoch in range(max_epochs):\n            if epoch % 100 == 0 and (time.time() - t_start) > time_limit:\n                break\n            optimizer.zero_grad()\n            pred = model(X_t)\n            loss = nn.functional.mse_loss(pred, Y_t)\n            loss.backward()\n            optimizer.step()\n            scheduler.step()\n\n            loss_val = loss.item()\n            if loss_val < best_loss:\n                best_loss = loss_val\n                best_state = {k_: v.cpu().clone() for k_, v in model.state_dict().items()}\n                no_improve = 0\n            else:\n                no_improve += 1\n\n            if loss_val < 1e-8:\n                break\n            if no_improve > patience:\n                break\n\n    if best_state is None:\n        return None\n\n    # Reload best state\n    if oa_mask is not None:\n        model = FXOMaskedCNN(hidden, k, oa_mask, n_layers, dilation).to(DEVICE)\n    else:\n        model = MaskedCNN(hidden, k, n_layers, dilation).to(DEVICE)\n    model.load_state_dict(best_state)\n    model.eval()\n\n    # Verify on training data\n    with torch.no_grad():\n        preds = model(X_t).cpu().numpy()\n    for i, p in enumerate(pairs):\n        og = np.asarray(p[\"output\"])\n        oh_, ow_ = og.shape\n        if tensor_to_grid(preds[i:i+1], oh_, ow_) != p[\"output\"]:\n            return None\n\n    # Export to ONNX\n    model.cpu()\n    model.eval()\n    buf = io.BytesIO()\n    dummy = torch.zeros(1, C, H, W)\n    try:\n        torch.onnx.export(model, dummy, buf, opset_version=17,\n                          input_names=[\"input\"], output_names=[\"output\"],\n                          dynamic_axes=None)\n    except Exception:\n        return None\n\n    buf.seek(0)\n    try:\n        onnx_model = onnx.load(buf)\n        onnx_model.ir_version = IR_VERSION\n        return onnx_model\n    except Exception:\n        return None\n\n\ndef try_cnn_solvers(pairs, all_pairs, time_budget=60):\n    \"\"\"\n    Try CNN configurations. Strict time budget.\n    Returns (model, label, cost) or (None, None, None).\n    \"\"\"\n    t_start = time.time()\n\n    # Lean config ladder: cheapest first, break on first success\n    cnn_configs = [\n        (8, 3, 1, 1, \"cnn_k3_h8\"),\n        (16, 3, 1, 1, \"cnn_k3_h16\"),\n        (8, 5, 1, 1, \"cnn_k5_h8\"),\n        (8, 3, 2, 1, \"cnn_k3_h8_2L\"),\n        (16, 5, 1, 1, \"cnn_k5_h16\"),\n        (16, 3, 2, 1, \"cnn_k3_h16_2L\"),\n        (8, 7, 1, 1, \"cnn_k7_h8\"),\n        (16, 9, 1, 1, \"cnn_k9_h16\"),\n        (32, 3, 2, 1, \"cnn_k3_h32_2L\"),\n        (16, 11, 1, 1, \"cnn_k11_h16\"),\n    ]\n\n    per_config_limit = max(15, time_budget // max(1, len(cnn_configs)))\n\n    for hidden, k, n_layers, dilation, name in cnn_configs:\n        if (time.time() - t_start) > time_budget:\n            break\n        try:\n            onnx_model = train_cnn_model(\n                pairs, hidden, k, n_layers, dilation,\n                max_epochs=1500, n_restarts=1, patience=250,\n                time_limit=per_config_limit\n            )\n            if onnx_model is None:\n                continue\n            if not check_fits(onnx_model):\n                continue\n            if not check_model_correct(onnx_model, all_pairs):\n                continue\n            c = compute_cost(onnx_model)\n            return onnx_model, name, c  # FIRST SUCCESS → done\n        except Exception:\n            continue\n\n    # FXO variant if I/O sizes differ\n    if not all_same_io_shape(pairs) and (time.time() - t_start) < time_budget:\n        for hidden, k, n_layers, dilation, name in cnn_configs[:4]:\n            if (time.time() - t_start) > time_budget:\