t_paths=task_prebuilts)\n        except Exception as e:\n            dt = time.time() - task_t0\n            print(f\"  {task_name}: SOLVE ERROR ({dt:.1f}s) — {e}\")\n            failed.append(task_name)\n            continue\n\n        if model is None:\n            dt = time.time() - task_t0\n            print(f\"  {task_name}: UNSOLVED ({dt:.1f}s)\")\n            failed.append(task_name)\n            continue\n\n        out_path = OUTPUT_DIR / f\"task{task_num}.onnx\"\n        try:\n            save_model(model, out_path)\n            onnx_paths.append(out_path)\n            solved.append(task_name)\n            sc = compute_score(c)\n            score_log.append((task_name, label, c, sc))\n            dt = time.time() - task_t0\n            print(f\"  {task_name}: ✅ [{label}]  cost={c:>10,}  score={sc:.2f}  ({dt:.1f}s)\")\n        except Exception as e:\n            print(f\"  {task_name}: SAVE ERROR — {e}\")\n            failed.append(task_name)\n\n        # Periodic cleanup\n        if (i + 1) % 50 == 0:\n            gc.collect()\n            if DEVICE == \"cuda\":\n                torch.cuda.empty_cache()\n\n    # Final Summary\n    n_solved = len(solved)\n    n_failed = len(failed)\n    est_score = sum(sc for _, _, _, sc in score_log) + (total_tasks - n_solved) * 1.0\n\n    print(f\"\\n{'='*60}\")\n    print(f\"SOLVED: {n_solved} / {total_tasks}  |  FAILED: {n_failed}\")\n    print(f\"ESTIMATED LB SCORE: {est_score:.1f}\")\n    print(f\"Time elapsed: {elapsed():.1f}s ({elapsed()/3600:.2f}h)\")\n    print(f\"{'='*60}\")\n\n    # Print breakdown by method\n    method_counts = Counter(label for _, label, _, _ in score_log)\n    method_scores = {}\n    for _, label, _, sc in score_log:\n        method_scores[label] = method_scores.get(label, 0) + sc\n    print(\"\\nMethod breakdown:\")\n    for method, count in method_counts.most_common():\n        avg_sc = method_scores[method] / count\n        print(f\"  {method:30s}: {count:3d} tasks, total={method_scores[method]:.1f}, avg={avg_sc:.1f}\")\n\n    # Create submission zip\n    if onnx_paths:\n        zip_path = OUTPUT_DIR / \"submission.zip\"\n        with zipfile.ZipFile(zip_path, \"w\", zipfile.ZIP_DEFLATED) as zf:\n            for f_ in onnx_paths:\n                zf.write(f_, f_.name)\n        print(f\"\\nsubmission.zip → {zip_path} ({zip_path.stat().st_size/1024:.1f} KB)\")\n    else:\n        print(\"\\nNo ONNX files produced.\")\n\n\nif __name__ == \"__main__\":\n    main()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-18T12:53:13.359771Z","iopub.execute_input":"2026-04-18T12:53:13.360013Z","iopub.status.idle":"2026-04-18T14:21:51.951519Z","shell.execute_reply.started":"2026-04-18T12:53:13.359985Z","shell.execute_reply":"2026-04-18T14:21:51.950775Z"}},"outputs":[{"name":"stdout","text":"Found 400 task files\nFound prebuilt ONNX solutions for 175 tasks\n  task001: ✅ [self_similar_tile]  cost=     1,369  score=17.78  (0.1s)\n  task002: ✅ [prebuilt_the-epic-sax-ensembler]  cost=    22,311  score=14.99  (0.7s)\n  task003: ✅ [prebuilt_the-epic-sax-ensembler]  cost=     2,870  score=17.04  (0.2s)\n  task004: ✅ [prebuilt_the-epic-sax-ensembler]  cost= 3,823,598  score=9.84  (0.2s)\n  task005: UNSOLVED (25.8s)\n  task006: ✅ [prebuilt_the-epic-sax-ensembler]  cost=    49,259  score=14.20  (0.1s)\n  task007: ✅ [prebuilt_the-epic-sax-ensembler]  cost=    15,553  score=15.35  (0.1s)\n  task008: ✅ [prebuilt_extracted_prebuilts]  cost=     5,770  score=16.34  (0.3s)\n  task009: UNSOLVED (21.9s)\n  task010: ✅ [prebuilt_the-epic-sax-ensembler]  cost=     4,425  score=16.60  (0.3s)\n  task011: UNSOLVED (21.0s)\n  task012: ✅ [lstsq_k5_b_m]  cost= 2,262,851  score=10.37  (0.1s)\n  task013: UNSOLVED (21.1s)\n  task014: UNSOLVED (28.5s)\n  task015: ✅ [prebuilt_the-epic-sax-ensembler]  cost=   814,734  score=11.39  (0.1s)\n  task016: ✅ [prebuilt_the-epic-sax-ensembler]  cost=       221  score=19.60  (0.0s)\n  task017: ✅ [lstsq_k11_b_m]  cost=10,950,854  score=8.7