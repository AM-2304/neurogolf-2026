torch.randn(1, C, H, W)\n    import io\n    buf = io.BytesIO()\n    torch.onnx.export(model, dummy, buf, input_names=[\"input\"], output_names=[\"output\"], opset_version=17)\n    buf.seek(0)\n    onnx_model = onnx.load(buf)\n    onnx_model.ir_version = IR_VERSION\n    return onnx_model\n\nprint(f\"CNN pipeline loaded ({DEVICE} mode)\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T22:03:51.575728Z","iopub.execute_input":"2026-04-16T22:03:51.576060Z","iopub.status.idle":"2026-04-16T22:03:51.601819Z","shell.execute_reply.started":"2026-04-16T22:03:51.576033Z","shell.execute_reply":"2026-04-16T22:03:51.601159Z"}},"outputs":[{"name":"stdout","text":"CNN pipeline loaded (cuda mode)\n","output_type":"stream"}],"execution_count":16},{"cell_type":"markdown","source":"# Detectors","metadata":{}},{"cell_type":"code","source":"# ============================================================\n#  Detectors - Original + NEW\n# ============================================================\n\ndef all_same_io_shape(pairs) -> bool:\n    return all(np.asarray(p[\"input\"]).shape == np.asarray(p[\"output\"]).shape for p in pairs)\n\ndef fixed_input_size(pairs):\n    if not pairs: return None\n    first = np.asarray(pairs[0][\"input\"]).shape\n    return first if all(np.asarray(p[\"input\"]).shape == first for p in pairs[1:]) else None\n\ndef fixed_output_size(pairs):\n    if not pairs: return None\n    first = np.asarray(pairs[0][\"output\"]).shape\n    return first if all(np.asarray(p[\"output\"]).shape == first for p in pairs[1:]) else None\n\ndef detect_identity(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.shape!=og.shape or not np.array_equal(ig,og): return False\n    return True\n\ndef detect_const(pairs):\n    if not pairs: return None\n    first=np.asarray(pairs[0][\"output\"])\n    for p in pairs[1:]:\n        o=np.asarray(p[\"output\"])\n        if o.shape!=first.shape or not np.array_equal(o,first): return None\n    if detect_identity(pairs): return None\n    return first\n\ndef detect_rotation(pairs):\n    for label,k in [(\"180\",2),(\"90cw\",-1),(\"90ccw\",1)]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            r=np.rot90(ig,k)\n            if r.shape!=og.shape or not np.array_equal(r,og): ok=False; break\n        if ok: return label\n    return None\n\ndef detect_flip(pairs):\n    for name,fn in [(\"h\",np.flipud),(\"w\",np.fliplr),(\"both\",lambda a:np.flipud(np.fliplr(a)))]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            if fn(ig).shape!=og.shape or not np.array_equal(fn(ig),og): ok=False; break\n        if ok: return name\n    return None\n\ndef detect_transpose(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.T.shape!=og.shape or not np.array_equal(ig.T,og): return False\n    return True\n\ndef detect_anti_transpose(pairs) -> bool:\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        exp=np.flipud(np.fliplr(ig.T))\n        if exp.shape!=og.shape or not np.array_equal(exp,og): return False\n    return True\n\ndef detect_color_map(pairs):\n    if not all_same_io_shape(pairs): return None\n    mapping: Dict[int,int]={}\n    for p in pairs:\n        for a,b in zip(np.asarray(p[\"input\"]).flatten().tolist(),\n                       np.asarray(p[\"output\"]).flatten().tolist()):\n            a,b=int(a),int(b)\n            if a in mapping and mapping[a]!=b: return None\n            mapping[a]=b\n    if all(k==v for k,v in mapping.items()): return None\n    return mapping\n\ndef detect_color_filter(pairs):\n    if not all_same_io_shape(pairs): return None\n    candidate=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        diff=(ig!=og)\n        if not np.any(diff): continue\n        if not np.all(og[diff]==0): return None\n        local=set(int(x) for x in ig[diff].tolist())\n        candidate=local if candidate is None else candidate|local\n    if not candidate: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]).copy()\n        for c_ in candidate: ig[ig==c_]=0\n        if not np.array_equal(ig,np.asarray(p[\"output\"])): return None\n    return candidate\n\ndef detect_fixed_crop(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    oh_,ow_=fst_out.shape; ih,iw=fst_in.shape\n    if oh_>ih or ow_>iw: return None\n    for r0 in range(ih-oh_+1):\n        for c0 in range(iw-ow_+1):\n            if not np.array_equal(fst_in[r0:r0+oh_,c0:c0+ow_],fst_out): continue\n            ok=True\n            for p in pairs[1:]:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if og.shape!=(oh_,ow_): ok=False; break\n                if r0+oh_>ig.shape[0] or c0+ow_>ig.shape[1]: ok=False; break\n                if not np.array_equal(ig[r0:r0+oh_,c0:c0+ow_],og): ok=False; break\n            if ok: return (r0,c0,oh_,ow_)\n    return None\n\ndef detect_translation(pairs):\n    if not all_same_io_shape(pairs): return None\n    fst_in=np.asarray(pairs[0][\"input\"]); ih,iw=fst_in.shape\n    for dr in range(-min(ih,11)+1,min(ih,11)):\n        for dc in range(-min(iw,11)+1,min(iw,11)):\n            if dr==0 and dc==0: continue\n            ok=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if ig.shape!=og.shape: ok=False; break\n                hh,ww=ig.shape\n                shifted=np.zeros_like(ig)\n                sr0=max(0,-dr); sr1=min(hh,hh-dr)\n                sc0=max(0,-dc); sc1=min(ww,ww-dc)\n                dr0=max(0,dr);  dc0=max(0,dc)\n                rh=sr1-sr0; rw=sc1-sc0\n                if rh>0 and rw>0:\n                    shifted[dr0:dr0+rh,dc0:dc0+rw]=ig[sr0:sr1,sc0:sc1]\n                if not np.array_equal(shifted,og): ok=False; break\n            if ok: return (dr,dc)\n    return None\n\ndef detect_upscale(pairs):\n    if not pairs: return None\n    for f in [2,3,4,5]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            ih,iw=ig.shape; oh_,ow_=og.shape\n            if oh_!=ih*f or ow_!=iw*f: ok=False; break\n            if ih*f>H or iw*f>W: ok=False; break\n            scaled=np.repeat(np.repeat(ig,f,axis=0),f,axis=1)\n            if not np.array_equal(scaled,og): ok=False; break\n        if ok: return f\n    return None\n\ndef detect_downscale(pairs):\n    if not pairs: return None\n    for f in [2,3,4,5]:\n        ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            ih,iw=ig.shape; oh_,ow_=og.shape\n            if ih!=oh_*f or iw!=ow_*f: ok=False; break\n            if not np.array_equal(ig[::f,::f],og): ok=False; break\n        if ok: return f\n    return None\n\ndef detect_tile(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    ih,iw=fst_in.shape; oh_,ow_=fst_out.shape\n    if ih==0 or iw==0 or oh_%ih!=0 or ow_%iw!=0: return None\n    tr,tc=oh_//ih,ow_//iw\n    if tr*ih>H or tc*iw>W or (tr==1 and tc==1): return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih2,iw2=ig.shape\n        if og.shape!=(ih2*tr,iw2*tc): return None\n        if not np.array_equal(np.tile(ig,(tr,tc)),og): return None\n    return (tr,tc)\n\ndef detect_concat_flip_w(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih,iw*2): return None\n        if not np.array_equal(np.concatenate([ig,np.fliplr(ig)],axis=1),og): return None\n    return True\n\ndef detect_concat_flip_h(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih*2,iw): return None\n        if not np.array_equal(np.concatenate([ig,np.flipud(ig)],axis=0),og): return None\n    return True\n\ndef detect_concat_rot180_w(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih,iw*2): return None\n        if not np.array_equal(np.concatenate([ig,np.rot90(ig,2)],axis=1),og): return None\n    return True\n\ndef detect_quadrant_mirror(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape\n        if og.shape!=(ih*2,iw*2): return None\n        top=np.concatenate([ig,np.fliplr(ig)],axis=1)\n        bot=np.concatenate([np.flipud(ig),np.rot90(ig,2)],axis=1)\n        if not np.array_equal(np.concatenate([top,bot],axis=0),og): return None\n    return True\n\ndef detect_row_broadcast(pairs):\n    if not all_same_io_shape(pairs): return None\n    chosen=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,_=ig.shape\n        matched=next((r for r in range(ih) if np.all(og==ig[r,:])),None)\n        if matched is None: return None\n        if chosen is None: chosen=matched\n        elif chosen!=matched: return None\n    return chosen\n\ndef detect_col_broadcast(pairs):\n    if not all_same_io_shape(pairs): return None\n    chosen=None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        _,iw=ig.shape\n        matched=next((c for c in range(iw) if np.all(og==ig[:,c:c+1])),None)\n        if matched is None: return None\n        if chosen is None: chosen=matched\n        elif chosen!=matched: return None\n    return chosen\n\ndef detect_crop_plus_color(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    oh_,ow_=fst_out.shape; ih,iw=fst_in.shape\n    if oh_>ih or ow_>iw: return None\n    for r0 in range(ih-oh_+1):\n        for c0 in range(iw-ow_+1):\n            cmap: Dict[int,int]={}\n            valid=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                if og.shape!=(oh_,ow_): valid=False; break\n                if r0+oh_>ig.shape[0] or c0+ow_>ig.shape[1]: valid=False; break\n                region=ig[r0:r0+oh_,c0:c0+ow_]\n                for a,b in zip(region.flatten().tolist(),og.flatten().tolist()):\n                    a,b=int(a),int(b)\n                    if a in cmap and cmap[a]!=b: valid=False; break\n                    cmap[a]=b\n                if not valid: break\n            if not valid: continue\n            if all(k==v for k,v in cmap.items()): continue\n            ok=True\n            for p in pairs:\n                ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n                region=ig[r0:r0+oh_,c0:c0+ow_]\n                mapped=region.copy()\n                for k,v in cmap.items(): mapped[region==k]=v\n                if not np.array_equal(mapped,og): ok=False; break\n            if ok: return (r0,c0,oh_,ow_,cmap)\n    return None\n\ndef detect_border_add(pairs):\n    if not pairs: return None\n    fst_in=np.asarray(pairs[0][\"input\"]); fst_out=np.asarray(pairs[0][\"output\"])\n    ih,iw=fst_in.shape; oh_,ow_=fst_out.shape\n    if (oh_-ih)!=(ow_-iw): return None\n    delta=oh_-ih\n    if delta<=0 or delta%2!=0: return None\n    b=delta//2\n    if not np.array_equal(fst_out[b:b+ih,b:b+iw],fst_in): return None\n    vals=set(fst_out[:b,:].flatten().tolist())\n    vals|=set(fst_out[-b:,:].flatten().tolist())\n    vals|=set(fst_out[:,:b].flatten().tolist())\n    vals|=set(fst_out[:,-b:].flatten().tolist())\n    if len(vals)!=1: return None\n    fill=int(vals.pop())\n    for p in pairs[1:]:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih2,iw2=ig.shape\n        if og.shape!=(ih2+2*b,iw2+2*b): return None\n        if not np.array_equal(og[b:b+ih2,b:b+iw2],ig): return None\n        m=np.zeros(og.shape,dtype=bool)\n        m[:b,:]=True; m[-b:,:]=True; m[:,:b]=True; m[:,-b:]=True\n        if not np.all(og[m]==fill): return None\n    return (b,fill)\n\ndef detect_rotation_plus_color(pairs):\n    for rot_label,k in [(\"180\",2),(\"90cw\",-1),(\"90ccw\",1)]:\n        mapping: Dict[int,int]={}; ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            r=np.rot90(ig,k)\n            if r.shape!=og.shape: ok=False; break\n            for a,b in zip(r.flatten().tolist(),og.flatten().tolist()):\n                a,b=int(a),int(b)\n                if a in mapping and mapping[a]!=b: ok=False; break\n                mapping[a]=b\n            if not ok: break\n        if ok and any(k2!=v for k2,v in mapping.items()): return (rot_label,mapping)\n    return None\n\ndef detect_flip_plus_color(pairs):\n    for name,fn in [(\"h\",np.flipud),(\"w\",np.fliplr),(\"both\",lambda a:np.flipud(np.fliplr(a)))]:\n        mapping: Dict[int,int]={}; ok=True\n        for p in pairs:\n            ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n            f=fn(ig)\n            if f.shape!=og.shape: ok=False; break\n            for a,b in zip(f.flatten().tolist(),og.flatten().tolist()):\n                a,b=int(a),int(b)\n                if a in mapping and mapping[a]!=b: ok=False; break\n                mapping[a]=b\n            if not ok: break\n        if ok and any(k2!=v for k2,v in mapping.items()): return (name,mapping)\n    return None\n\ndef detect_transpose_plus_color(pairs):\n    mapping: Dict[int,int]={}\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        if ig.T.shape!=og.shape: return None\n        for a,b in zip(ig.T.flatten().tolist(),og.flatten().tolist()):\n            a,b=int(a),int(b)\n            if a in mapping and mapping[a]!=b: return None\n            mapping[a]=b\n    if any(k!=v for k,v in mapping.items()): return mapping\n    return None\n\n\ndef detect_self_similar_tile(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig=np.asarray(p[\"input\"]); og=np.asarray(p[\"output\"])\n        ih,iw=ig.shape; oh_,ow_=og.shape\n        if oh_!=ih*ih or ow_!=iw*iw: return None\n        if oh_>H or ow_>W: return None\n        for br in range(ih):\n            for bc in range(iw):\n                block=og[br*ih:(br+1)*ih, bc*iw:(bc+1)*iw]\n                if ig[br,bc]!=0:\n                    if not np.array_equal(block,ig): return None\n                else:\n                    if not np.all(block==0): return None\n    return True\n\n\n# ============================================================\n#  NEW DETECTORS\n# ============================================================\n\ndef detect_gravity_down(pairs):\n    \"\"\"Detect: non-zero pixels fall to bottom of grid (per column).\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        expected = np.zeros_like(ig)\n        for c in range(w):\n            col = [v for v in ig[:, c] if v != 0]\n            for i, v in enumerate(reversed(col)):\n                expected[h - 1 - i, c] = v\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_gravity_up(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        expected = np.zeros_like(ig)\n        for c in range(w):\n            col = [v for v in ig[:, c] if v != 0]\n            for i, v in enumerate(col):\n                expected[i, c] = v\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_gravity_left(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        expected = np.zeros_like(ig)\n        for r in range(h):\n            row = [v for v in ig[r, :] if v != 0]\n            for i, v in enumerate(row):\n                expected[r, i] = v\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_gravity_right(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        expected = np.zeros_like(ig)\n        for r in range(h):\n            row = [v for v in ig[r, :] if v != 0]\n            for i, v in enumerate(reversed(row)):\n                expected[r, w - 1 - i] = v\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_majority_color(pairs):\n    \"\"\"Per-pixel majority: output is a uniform grid filled with the most common non-zero color.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        nonzero = ig[ig != 0]\n        if len(nonzero) == 0: return None\n        mc = int(Counter(nonzero.tolist()).most_common(1)[0][0])\n        expected = np.full_like(ig, mc)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_keep_largest_color(pairs):\n    \"\"\"Output keeps only the most frequent non-background color, zeros everything else.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        nonzero = ig[ig != 0]\n        if len(nonzero) == 0: return None\n        mc = int(Counter(nonzero.tolist()).most_common(1)[0][0])\n        expected = np.where(ig == mc, ig, 0)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_fill_background(pairs):\n    \"\"\"Detect: pixels that are 0 in input become a specific color in output; non-zero stay same.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    fill_color = None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        if not np.array_equal(ig[ig!=0], og[ig!=0]): return None\n        bg_mask = (ig == 0)\n        if not np.any(bg_mask): continue\n        bg_vals = og[bg_mask]\n        if len(set(bg_vals.tolist())) != 1: return None\n        fc = int(bg_vals[0])\n        if fill_color is None: fill_color = fc\n        elif fill_color != fc: return None\n    if fill_color is None or fill_color == 0: return None\n    return fill_color\n\ndef detect_swap_two_colors(pairs):\n    \"\"\"Detect: exactly two colors are swapped, everything else unchanged.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    swap_pair = None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        diff_mask = ig != og\n        if not np.any(diff_mask): continue\n        src = set(ig[diff_mask].tolist())\n        dst = set(og[diff_mask].tolist())\n        if len(src) != 2 or src != dst: return None\n        pair = tuple(sorted(src))\n        if swap_pair is None: swap_pair = pair\n        elif swap_pair != pair: return None\n        a, b = pair\n        expected = ig.copy()\n        expected[ig == a] = b\n        expected[ig == b] = a\n        if not np.array_equal(expected, og): return None\n    return swap_pair\n\ndef detect_replace_color_with_another(pairs):\n    \"\"\"All instances of color A become color B, everything else unchanged.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    found_a, found_b = None, None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        diff_mask = ig != og\n        if not np.any(diff_mask): continue\n        src_vals = set(ig[diff_mask].tolist())\n        dst_vals = set(og[diff_mask].tolist())\n        if len(src_vals) != 1 or len(dst_vals) != 1: return None\n        a, b = src_vals.pop(), dst_vals.pop()\n        if found_a is None: found_a, found_b = a, b\n        elif found_a != a or found_b != b: return None\n        unchanged = ~diff_mask\n        if not np.array_equal(ig[unchanged], og[unchanged]): return None\n    if found_a is not None:\n        return {found_a: found_b}\n    return None\n\ndef detect_horizontal_mirror_left_to_right(pairs):\n    \"\"\"Left half is source, right half becomes its mirror.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        if w % 2 != 0: return None\n        hw = w // 2\n        left = ig[:, :hw]\n        expected = np.concatenate([left, np.fliplr(left)], axis=1)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_horizontal_mirror_right_to_left(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        if w % 2 != 0: return None\n        hw = w // 2\n        right = ig[:, hw:]\n        expected = np.concatenate([np.fliplr(right), right], axis=1)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_vertical_mirror_top_to_bottom(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        if h % 2 != 0: return None\n        hh = h // 2\n        top = ig[:hh, :]\n        expected = np.concatenate([top, np.flipud(top)], axis=0)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_vertical_mirror_bottom_to_top(pairs):\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        if h % 2 != 0: return None\n        hh = h // 2\n        bottom = ig[hh:, :]\n        expected = np.concatenate([np.flipud(bottom), bottom], axis=0)\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_max_pool(pairs):\n    \"\"\"Channel-wise max-pool 2x2 or 3x3 (on the integer grid: take most common nonzero color in block).\"\"\"\n    if not pairs: return None\n    for f in [2, 3]:\n        ok = True\n        for p in pairs:\n            ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n            ih, iw = ig.shape; oh_, ow_ = og.shape\n            if ih != oh_ * f or iw != ow_ * f:\n                ok = False; break\n            for r in range(oh_):\n                for c in range(ow_):\n                    block = ig[r*f:(r+1)*f, c*f:(c+1)*f].flatten()\n                    nz = [v for v in block if v != 0]\n                    exp = Counter(nz).most_common(1)[0][0] if nz else 0\n                    if og[r, c] != exp:\n                        ok = False; break\n                if not ok: break\n            if not ok: break\n        if ok: return f\n    return None\n\ndef detect_outline(pairs):\n    \"\"\"Output keeps only border pixels of each colored region (interior becomes 0).\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        expected = np.zeros_like(ig)\n        for r in range(h):\n            for c in range(w):\n                if ig[r, c] == 0: continue\n                is_border = False\n                for dr, dc in [(-1,0),(1,0),(0,-1),(0,1)]:\n                    nr, nc = r+dr, c+dc\n                    if nr < 0 or nr >= h or nc < 0 or nc >= w or ig[nr, nc] != ig[r, c]:\n                        is_border = True; break\n                if is_border:\n                    expected[r, c] = ig[r, c]\n        if not np.array_equal(expected, og): return None\n    return True\n\ndef detect_fill_interior(pairs):\n    \"\"\"Interior holes (0-pixels completely surrounded by non-zero) get filled with surrounding color.\"\"\"\n    if not all_same_io_shape(pairs): return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        h, w = ig.shape\n        if np.array_equal(ig, og): return None\n        # Check non-zero pixels are preserved\n        mask = ig != 0\n        if not np.array_equal(ig[mask], og[mask]): return None\n        # Check that newly filled pixels are surrounded\n        diff = (ig == 0) & (og != 0)\n        if not np.any(diff): return None\n    return True  # approximate; CNN will learn the exact rule\n\ndef detect_concat_self_h(pairs):\n    \"\"\"Output is [input; input] vertically.\"\"\"\n    if not pairs: return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        ih, iw = ig.shape\n        if og.shape != (ih*2, iw): return None\n        if not np.array_equal(np.concatenate([ig, ig], axis=0), og): return None\n    return True\n\ndef detect_concat_self_w(pairs):\n    \"\"\"Output is [input, input] horizontally.\"\"\"\n    if not pairs: return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        ih, iw = ig.shape\n        if og.shape != (ih, iw*2): return None\n        if not np.array_equal(np.concatenate([ig, ig], axis=1), og): return None\n    return True\n\nprint(\"All detectors loaded\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T22:03:51.603910Z","iopub.execute_input":"2026-04-16T22:03:51.604341Z","iopub.status.idle":"2026-