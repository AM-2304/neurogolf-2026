turn _make_model(base_nodes+[gi,gnode,mk,mul],\"xform_color_masked\")\n\n\ndef make_self_similar_tile(in_h, in_w):\n    out_h = in_h * in_h\n    out_w = in_w * in_w\n    if out_h > H or out_w > W:\n        return None\n    nodes = _crop_to_content(\"input\",\"content\",in_h,in_w,\"sst0\")\n    nodes += [\n        _const(\"sst_cs0\", np.asarray([0], dtype=np.int64)),\n        _const(\"sst_ce0\", np.asarray([1], dtype=np.int64)),\n        _const(\"sst_ca0\", np.asarray([1], dtype=np.int64)),\n        oh.make_node(\"Slice\",[\"content\",\"sst_cs0\",\"sst_ce0\",\"sst_ca0\"],[\"bg_ch\"]),\n        _const(\"sst_one\", np.ones((1,1,1,1), dtype=np.float32)),\n        oh.make_node(\"Sub\",[\"sst_one\",\"bg_ch\"],[\"presence\"]),\n    ]\n    nodes += [\n        _const(\"sst_roi\",    np.asarray([], dtype=np.float32)),\n        _const(\"sst_scales\", np.asarray([], dtype=np.float32)),\n        _const(\"sst_sizes\",  np.asarray([1,1,out_h,out_w], dtype=np.int64)),\n        oh.make_node(\"Resize\",[\"presence\",\"sst_roi\",\"sst_scales\",\"sst_sizes\"],[\"pres_up\"],\n                     mode=\"nearest\",\n                     coordinate_transformation_mode=\"asymmetric\",\n                     nearest_mode=\"floor\"),\n    ]\n    nodes += [\n        _const(\"sst_reps\", np.asarray([1,1,in_h,in_w], dtype=np.int64)),\n        oh.make_node(\"Tile\",[\"content\",\"sst_reps\"],[\"tiled\"]),\n    ]\n    nodes += [oh.make_node(\"Mul\",[\"tiled\",\"pres_up\"],[\"masked\"])]\n    nodes += _pad_to_canvas(\"masked\",\"output\",out_h,out_w,\"sstp\")\n    return _make_model(nodes,\"self_similar_tile\")\n\nprint(\"Model builders loaded\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T22:03:51.503699Z","iopub.execute_input":"2026-04-16T22:03:51.504211Z","iopub.status.idle":"2026-04-16T22:03:51.574655Z","shell.execute_reply.started":"2026-04-16T22:03:51.504180Z","shell.execute_reply":"2026-04-16T22:03:51.573631Z"}},"outputs":[{"name":"stdout","text":"Model builders loaded\n","output_type":"stream"}],"execution_count":15},{"cell_type":"markdown","source":"# Mini CNN Trainer","metadata":{}},{"cell_type":"code","source":"# ============================================================\n#  Trained CNN -> ONNX pipeline\n#  Auto-detects GPU (T4/L4) vs CPU fallback (P100).\n# ============================================================\n\nclass TinyConvNet(nn.Module):\n    def __init__(self, mid_channels=16, use_3x3=False, depth=1):\n        super().__init__()\n        layers = []\n        in_c = C\n        for i in range(depth):\n            mc = mid_channels\n            layers.append(nn.Conv2d(in_c, mc, 1, bias=True))\n            layers.append(nn.ReLU())\n            if use_3x3:\n                layers.append(nn.Conv2d(mc, mc, 3, padding=1, bias=True))\n                layers.append(nn.ReLU())\n            in_c = mc\n        layers.append(nn.Conv2d(in_c, C, 1, bias=True))\n        self.net = nn.Sequential(*layers)\n\n    def forward(self, x):\n        return self.net(x)\n\nclass ResConvNet(nn.Module):\n    def __init__(self, mid_ch=20, n_blocks=2, kernel=3):\n        super().__init__()\n        pad = kernel // 2\n        self.proj_in = nn.Conv2d(C, mid_ch, 1, bias=True)\n        blocks = []\n        for _ in range(n_blocks):\n            blocks.append(nn.Sequential(\n                nn.ReLU(),\n                nn.Conv2d(mid_ch, mid_ch, kernel, padding=pad, bias=True),\n                nn.ReLU(),\n                nn.Conv2d(mid_ch, mid_ch, 1, bias=True),\n            ))\n        self.blocks = nn.ModuleList(blocks)\n        self.proj_out = nn.Conv2d(mid_ch, C, 1, bias=True)\n\n    def forward(self, x):\n        h = self.proj_in(x)\n        for blk in self.blocks:\n            h = h + blk(h)\n        return self.proj_out(h)\n\nCNN_CONFIGS = [\n    (\"1x1_d1_8\",    lambda: TinyConvNet(8,  False, 1)),\n    (\"1x1_d1_16\",   lambda: TinyConvNet(16, False, 1)),\n    (\"1x1_d1_24\",   lambda: TinyConvNet(24, False, 1)),\n    (\"3x3_d1_8\",    lambda: TinyConvNet(8,  True,  1)),\n    (\"3x3_d1_16\",   lambda: TinyConvNet(16, True,  1)),\n    (\"1x1_d2_12\",   lambda: TinyConvNet(12, False, 2)),\n    (\"1x1_d2_16\",   lambda: TinyConvNet(16, False, 2)),\n    (\"3x3_d1_24\",   lambda: TinyConvNet(24, True,  1)),\n    (\"3x3_d2_12\",   lambda: TinyConvNet(12, True,  2)),\n    (\"3x3_d2_16\",   lambda: TinyConvNet(16, True,  2)),\n    (\"res_16_2\",    lambda: ResConvNet(16, 2, 3)),\n    (\"res_20_2\",    lambda: ResConvNet(20, 2, 3)),\n    (\"res_24_3\",    lambda: ResConvNet(24, 3, 3)),\n    (\"res_32_2\",    lambda: ResConvNet(32, 2, 3)),\n    (\"res_32_3_k5\", lambda: ResConvNet(32, 3, 5)),\n    (\"res_48_3\",    lambda: ResConvNet(48, 3, 3)),\n]\n\ndef _verify_exact(model, pairs):\n    model.eval()\n    with torch.no_grad():\n        for p in pairs:\n            # Always run verification on CPU for tensor_to_grid compatibility\n            inp = torch.from_numpy(grid_to_tensor(p[\"input\"]))\n            pred = model(inp.to(next(model.parameters()).device)).cpu().numpy()\n            og = np.asarray(p[\"output\"])\n            oh_, ow_ = og.shape\n            outside = pred.copy()\n            outside[0, :, :oh_, :ow_] = 0.0\n            if np.max(np.abs(outside)) > 1e-4: return False\n            if tensor_to_grid(pred, oh_, ow_) != p[\"output\"]: return False\n    return True\n\ndef train_cnn_for_task(pairs, max_epochs=3000, patience=400, verbose=True):\n    \"\"\"Train progressively larger CNNs. Returns the smallest correct one.\"\"\"\n    X_t = torch.from_numpy(np.concatenate([grid_to_tensor(p[\"input\"]) for p in pairs], axis=0)).to(DEVICE)\n    Y_t = torch.from_numpy(np.concatenate([grid_to_tensor(p[\"output\"]) for p in pairs], axis=0)).to(DEVICE)\n\n    for cfg_label, factory in CNN_CONFIGS:\n        if verbose: print(f\"    - Testing arch: {cfg_label}...\", end=\" \", flush=True)\n        \n        best_state = None\n        best_loss_ever = float(\"inf\")\n        \n        for restart in