axis=1), og): return None\n    return True\n\ndef detect_concat_rot180_h(pairs):\n    if not pairs: return None\n    for p in pairs:\n        ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n        ih, iw = ig.shape\n        if og.shape != (ih*2, iw): return None\n        if not np.array_equal(np.concatenate([ig, np.rot90(ig, 2)], axis=0), og): return None\n    return True\n\ndef make_concat_rot180_h(in_h, in_w):\n    nodes = _crop_to_content(\"input\", \"content\", in_h, in_w, \"crh0\")\n    nodes += _slice_reverse([2,3], [in_h, in_w], \"content\", \"rotated\", \"crhr\")\n    nodes += [oh.make_node(\"Concat\", [\"content\", \"rotated\"], [\"concated\"], axis=2)]\n    nodes += _pad_to_canvas(\"concated\", \"output\", in_h*2, in_w, \"crhp\")\n    return _make_model(nodes, \"concat_rot180_h\")\n\n\ndef detect_upscale_with_color(pairs):\n    \"\"\"Upscale + color remap.\"\"\"\n    if not pairs: return None\n    for f in [2, 3, 4, 5]:\n        mapping: Dict[int, int] = {}\n        ok = True\n        for p in pairs:\n            ig = np.asarray(p[\"input\"]); og = np.asarray(p[\"output\"])\n            ih, iw = ig.shape; oh_, ow_ = og.shape\n            if oh_ != ih*f or ow_ != iw*f: ok = False; break\n            if ih*f > H or iw*f > W: ok = False; break\n            scaled = np.repeat(np.repeat(ig, f, axis=0), f, axis=1)\n            for a, b in zip(scaled.flatten().tolist(), og.flatten().tolist()):\n                a, b = int(a), int(b)\n                if a in mapping and mapping[a] != b: ok = False; break\n                mapping[a] = b\n            if not ok: break\n        if ok and any(k != v for k, v in mapping.items()):\n            return (f, mapping)\n    return None\n\n\ndef detect_fixed_output_not_const(pairs):\n    \"\"\"All outputs are different from inputs but have same fixed size. \n    This means CNN training is viable.\"\"\"\n    if not pairs: return None\n    out_shapes = set()\n    for p in pairs:\n        og = np.asarray(p[\"output\"])\n        out_shapes.add(og.shape)\n    return len(out_shapes) == 1\n\nprint(\"New model builders loaded\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T22:03:51.704352Z","iopub.execute_input":"2026-04-16T22:03:51.704662Z","iopub.status.idle":"2026-04-16T22:03:51.734012Z","shell.execute_reply.started":"2026-04-16T22:03:51.704635Z","shell.execute_reply":"2026-04-16T22:03:51.733011Z"}},"outputs":[{"name":"stdout","text":"New model builders loaded\n","output_type":"stream"}],"execution_count":18},{"cell_type":"markdown","source":"# Orchestrator","metadata":{}},{"cell_type":"code","source":"# ============================================================\n#  Orchestrator - rule-based candidates (original + new)\n# ============================================================\n\ndef _candidates(train_pairs, all_pairs):\n    fixed_sz = fixed_input_size(all_pairs)\n    is_full  = (fixed_sz == (H, W))\n    same_shape = all_same_io_shape(train_pairs)\n\n    # Identity\n    if detect_identity(train_pairs):\n        yield \"identity\", make_identity\n\n    # Rotation / flip / transpose\n    rot = detect_rotation(train_pairs)\n    if rot == \"180\":\n        if is_full: yield \"rot180\", make_rot_180\n        if fixed_sz:\n            h,w=fixed_sz\n            yield \"rot180_framed\", (lambda h=h,w=w: make_framed_rot180(h,w))\n    if rot == \"90cw\":\n        if is_full: yield \"rot90cw\", make_rot_90_cw\n        if fixed_sz:\n            h,w=fixed_sz\n            yield \"rot90cw_framed\", (lambda h=h,w=w: make_framed_rot_90_cw(h,w))\n    if rot == \"90ccw\":\n        if is_full: yield \"rot90ccw\", make_rot_90_ccw\n        if fixed_sz:\n            h,w=fixed_sz\n            yield \"rot90ccw_framed\", (lambda h=h,w=w: make_framed_rot_90_ccw(h,w))\n\n    flip = detect_flip(train_pairs)\n    if flip == \"h\":\n        if is_full: yield \"flip_h\", make_flip_h\n        if fixed_sz:\n            h,w=fixed_sz\n            yield \"flip_h_framed\", (lambd